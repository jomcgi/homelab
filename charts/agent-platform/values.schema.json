{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["goose", "secrets"],
  "properties": {
    "goose": {
      "type": "object",
      "required": ["repo", "workspace"],
      "properties": {
        "repo": {
          "type": "object",
          "required": ["owner", "name"],
          "properties": {
            "owner": {
              "type": "string",
              "description": "GitHub org or user owning the target repo"
            },
            "name": {
              "type": "string",
              "description": "GitHub repo name to clone into sandboxes"
            }
          },
          "additionalProperties": false
        },
        "workspace": {
          "type": "object",
          "required": ["storageClassName"],
          "properties": {
            "storageClassName": {
              "type": "string",
              "description": "Kubernetes StorageClass for sandbox workspace PVCs"
            },
            "size": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          },
          "additionalProperties": true
        },
        "model": { "type": "string" },
        "provider": { "type": "string" },
        "recipes": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "secrets": {
      "type": "object",
      "properties": {
        "useOnePassword": { "type": "boolean" },
        "claudeAuth": {
          "type": "object",
          "properties": {
            "secretName": { "type": "string" },
            "key": { "type": "string" },
            "onePasswordItem": { "type": "string" },
            "vault": { "type": "string" }
          },
          "additionalProperties": false
        },
        "agentSecrets": {
          "type": "object",
          "additionalProperties": true
        },
        "mcpTokens": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "properties": {
        "grafana": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } },
          "additionalProperties": true
        },
        "argocd": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } },
          "additionalProperties": true
        },
        "mcpServers": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "contextForge": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy the Context Forge MCP gateway as part of this release"
        }
      },
      "additionalProperties": true
    },
    "mcpOAuthProxy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy the MCP OAuth Proxy (Google OIDC, ADR 006) as part of this release"
        }
      },
      "additionalProperties": true
    },
    "nats": { "type": "object", "additionalProperties": true },
    "agent-orchestrator": { "type": "object", "additionalProperties": true },
    "agent-sandbox": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "installCRDs": {
          "type": "boolean",
          "description": "Install agent-sandbox CRDs. Set false for parallel installs where CRDs already exist."
        },
        "deployController": {
          "type": "boolean",
          "description": "Deploy the agent-sandbox controller StatefulSet. Set false when another release already runs it."
        }
      },
      "additionalProperties": true
    },
    "goose-sandboxes": { "type": "object", "additionalProperties": true },
    "agent-platform-mcp-servers": {
      "type": "object",
      "additionalProperties": true
    },
    "context-forge": { "type": "object", "additionalProperties": true },
    "mcp-oauth-proxy": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
