{
  "$schema": "https://opencode.ai/config.json",

  // Primary model for main tasks
  "model": "google/gemini-3-flash-preview",

  // Smaller model for lightweight tasks (title generation, summaries)
  "small_model": "llama-cpp/hermes-4.3-36b",

  // Username shown in conversation (optional)
  "username": "jomcgi",

  "provider": {
    "google": {
      "models": {
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        }
      },
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}"
      }
    },
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp Local",
      "options": {
        "baseURL": "http://llama-cpp.llama-cpp.svc.cluster.local:8080/v1"
      },
      "models": {
        "hermes-4.3-36b": {
          "name": "Hermes 4.3 36B",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },

  // Agent configuration for different workflows
  "agent": {
    // Fast local agent - for quick tasks without deep reasoning
    "cheap-local-tokens": {
      "model": "llama-cpp/hermes-4.3-36b",
      "temperature": 0.3,
      "mode": "primary"
    },
    // Long context agent - for tasks needing deep context understanding
    "long-context-window-tasks": {
      "model": "google/gemini-3-flash-preview",
      "temperature": 0.5,
      "mode": "primary"
    }
  },

  // Permissions - allow everything since sessions run in sandboxed pods
  "permission": {
    // Allow all bash commands (sandboxed environment)
    "bash": {
      "*": "allow"
    },
    // Allow all file edits
    "edit": "allow",
    // Allow all web fetches
    "webfetch": "allow"
  },

  // Session sharing (useful for collaboration)
  "share": "manual",

  // Additional instruction files to load
  "instructions": ["**/.claude/CLAUDE.md", "**/CLAUDE.md"]
}
