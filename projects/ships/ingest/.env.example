# AIS Ingest Configuration

# NATS server connection
NATS_URL=nats://localhost:4222

# AISStream.io API key (required)
AISSTREAM_API_KEY=your-api-key-here

# AISStream WebSocket endpoint
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream

# Geographic bounding box filter (JSON array)
# Format: [[[lat_min, lon_min], [lat_max, lon_max]]]
BOUNDING_BOX=[[[46.876152, -129.552155], [51.413769, -121.213531]]]
