# Ships API Configuration

# NATS server connection
NATS_URL=nats://localhost:4222

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# SQLite database path
DB_PATH=/tmp/ships.db

# Position history retention (days)
POSITION_RETENTION_DAYS=7

# Catchup threshold - pending messages below this = caught up
CATCHUP_PENDING_THRESHOLD=10000

# Deduplication settings
DEDUP_DISTANCE_METERS=100
DEDUP_SPEED_THRESHOLD=0.5
DEDUP_TIME_THRESHOLD=300

# Moored vessel detection
MOORED_RADIUS_METERS=500
MOORED_MIN_DURATION_HOURS=1
