{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "context-forge": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy the Context Forge MCP gateway"
        },
        "mcp-stack": { "type": "object" },
        "secret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "itemPath": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "mcp-oauth-proxy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy the MCP OAuth Proxy (Google OIDC, ADR 006)"
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "config": { "type": "object" },
        "secret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "itemPath": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "agent-platform-mcp-servers": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "servers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "image", "port"],
            "properties": {
              "name": { "type": "string" },
              "image": {
                "type": "object",
                "required": ["repository", "tag"],
                "properties": {
                  "repository": { "type": "string" },
                  "tag": { "type": "string" }
                }
              },
              "port": { "type": "integer" },
              "args": { "type": "array", "items": { "type": "string" } },
              "env": { "type": "array" },
              "writableTmp": { "type": "boolean" },
              "resources": { "type": "object" },
              "registration": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "transport": {
                    "type": "string",
                    "enum": ["STREAMABLEHTTP", "SSE", "STDIO"]
                  }
                }
              },
              "alert": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "url": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "agent-orchestrator": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "natsUrl": { "type": "string" },
            "sandboxNamespace": { "type": "string" },
            "sandboxTemplate": { "type": "string" },
            "maxRetries": { "type": "string" },
            "maxConcurrent": { "type": "string" }
          }
        },
        "httpRoute": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "hostname": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "goose-sandboxes": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sandboxTemplate": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "image": {
              "type": "object",
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" }
              }
            },
            "env": {
              "type": "object",
              "properties": {
                "gooseProvider": { "type": "string" },
                "gooseModel": { "type": "string" },
                "contextForgeUrl": { "type": "string" },
                "repoOwner": { "type": "string" },
                "repoName": { "type": "string" }
              }
            },
            "workspace": {
              "type": "object",
              "properties": {
                "storageClassName": { "type": "string" },
                "size": { "type": "string" }
              }
            }
          }
        },
        "secrets": {
          "type": "object",
          "properties": {
            "useOnePassword": { "type": "boolean" }
          }
        }
      },
      "additionalProperties": true
    },
    "agent-sandbox": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "installCRDs": {
          "type": "boolean",
          "description": "Install agent-sandbox CRDs. Set false for parallel installs."
        },
        "deployController": {
          "type": "boolean",
          "description": "Deploy the controller. Set false when another release already runs it."
        }
      },
      "additionalProperties": true
    },
    "nats": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
