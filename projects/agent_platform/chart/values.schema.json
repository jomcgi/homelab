{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy default-deny baseline + per-service NetworkPolicies"
        }
      }
    },
    "agent-orchestrator": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "natsUrl": { "type": "string" },
            "sandboxNamespace": { "type": "string" },
            "sandboxTemplate": { "type": "string" },
            "maxRetries": { "type": "string" },
            "maxConcurrent": { "type": "string" }
          }
        },
        "httpRoute": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "hostname": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "goose-sandboxes": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sandboxTemplate": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "image": {
              "type": "object",
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" }
              }
            },
            "env": {
              "type": "object",
              "properties": {
                "gooseProvider": { "type": "string" },
                "gooseModel": { "type": "string" },
                "contextForgeUrl": { "type": "string" },
                "repoOwner": { "type": "string" },
                "repoName": { "type": "string" }
              }
            },
            "workspace": {
              "type": "object",
              "properties": {
                "storageClassName": { "type": "string" },
                "size": { "type": "string" }
              }
            }
          }
        },
        "secrets": {
          "type": "object",
          "properties": {
            "useOnePassword": { "type": "boolean" }
          }
        }
      },
      "additionalProperties": true
    },
    "agent-sandbox": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "installCRDs": {
          "type": "boolean",
          "description": "Install agent-sandbox CRDs. Set false for parallel installs."
        },
        "deployController": {
          "type": "boolean",
          "description": "Deploy the controller. Set false when another release already runs it."
        }
      },
      "additionalProperties": true
    },
    "nats": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
