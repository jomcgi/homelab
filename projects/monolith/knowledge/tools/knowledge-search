#!/usr/bin/env python3
"""Semantic search for the knowledge gardener.
Usage: knowledge-search <query>
Prints JSON array of matching notes to stdout.
"""
import asyncio
import json
import logging
import math
import os
import sys

logger = logging.getLogger("knowledge.search")


async def main() -> None:
    query = " ".join(sys.argv[1:]).strip()
    if not query:
        print("[]")
        return
    db_url = os.environ.get("DATABASE_URL")
    if not db_url:
        print("knowledge-search: DATABASE_URL not set", file=sys.stderr)
        print("[]")
        return
    from shared.embedding import EmbeddingClient
    from knowledge.store import KnowledgeStore
    from sqlmodel import Session, create_engine

    engine = create_engine(db_url)
    try:
        embed_client = EmbeddingClient()
        embedding = await embed_client.embed(query)
        with Session(engine) as session:
            results = KnowledgeStore(session=session).search_notes(
                query_embedding=embedding, limit=5
            )
        safe_results = [r for r in results if isinstance(r.get("score"), (int, float)) and math.isfinite(r["score"])]
        print(json.dumps(safe_results))
    except Exception:
        logger.exception("knowledge-search: error during search")
        print("[]")


asyncio.run(main())
