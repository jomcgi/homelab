# projects/nexus/caddy/Caddyfile
:3000 {
    # Proxy API requests to FastAPI sidecar
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # Proxy healthz to FastAPI
    handle /healthz {
        reverse_proxy localhost:8000
    }

    # Serve SvelteKit static build
    handle {
        root * /srv
        try_files {path} {path}/ /index.html
        file_server
    }
}
