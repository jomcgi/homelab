---
interface Props {
    diagram: string;
    id?: string;
}

const { diagram, id = `mermaid-${Math.random().toString(36).slice(2, 9)}` } = Astro.props;
// Encode the diagram to safely store in data attribute
const encodedDiagram = Buffer.from(diagram).toString('base64');
---

<div class="mermaid-container">
    <pre class="mermaid" id={id} data-diagram={encodedDiagram}>{diagram}</pre>
</div>
