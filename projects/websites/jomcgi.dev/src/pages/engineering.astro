    <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

        function getMermaidConfig() {
            const isDark = document.body.classList.contains('dark');
            return {
                theme: 'base',
                themeVariables: {
                    primaryColor: 'transparent',
                    primaryBorderColor: isDark ? '#fff' : '#000',
                    primaryTextColor: isDark ? '#fff' : '#000',
                    lineColor: isDark ? '#fff' : '#000',
                    fontFamily: "'Courier New', Courier, monospace",
                    fontSize: '12px',
                    background: 'transparent',
                    mainBkg: 'transparent',
                    edgeLabelBackground: isDark ? '#000' : '#fff',
                    tertiaryColor: isDark ? '#000' : '#fff',
                    clusterBkg: 'transparent',
                    clusterBorder: '#888',
                }
            };
        }

        async function renderMermaidDiagrams() {
            mermaid.initialize({
                startOnLoad: false,
                ...getMermaidConfig()
            });

            const diagrams = document.querySelectorAll('.mermaid');
            for (const diagram of diagrams) {
                const id = diagram.id || `mermaid-${Date.now()}`;
                const encodedDiagram = diagram.dataset.diagram;
                const graphDefinition = encodedDiagram
                    ? atob(encodedDiagram)
                    : (diagram.textContent || diagram.innerText);

                try {
                    const renderId = `${id}-${Date.now()}`;
                    const { svg } = await mermaid.render(renderId, graphDefinition);
                    diagram.innerHTML = svg;
                } catch (error) {
                    console.error('Mermaid rendering error:', error);
                }
            }
        }

        const observer = new MutationObserver(() => renderMermaidDiagrams());
        observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });

        renderMermaidDiagrams();
    </script>

    <script is:inline>
        // Keyboard navigation: Arrow keys to jump between sections
        (function() {
            function getAnchors() {
                return Array.from(document.querySelectorAll('section.deep-dive[id], .subsection'));
            }

            function getCurrentIndex(anchors) {
                const scrollY = window.scrollY + 100;
                for (let i = anchors.length - 1; i >= 0; i--) {
                    if (anchors[i].offsetTop <= scrollY) return i;
                }
                return 0;
            }

            document.addEventListener('keydown', (e) => {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

                const anchors = getAnchors();
                if (!anchors.length) return;

                const current = getCurrentIndex(anchors);

                if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
                    e.preventDefault();
                    const next = Math.min(current + 1, anchors.length - 1);
                    anchors[next].scrollIntoView({ behavior: 'smooth', block: 'start' });
                } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
                    e.preventDefault();
                    const prev = Math.max(current - 1, 0);
                    anchors[prev].scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        })();
    </script>
