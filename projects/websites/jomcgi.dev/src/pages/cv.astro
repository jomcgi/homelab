---
import '../styling/cv.css';
import { Markdown } from 'astro-remote';
import cvContent from '../assets/cv.md?raw';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Joe McGinley - Senior Platform Engineer @ BenchSci | GCP | Kubernetes | Go | Python | Reliability">
    <title>Joe - Senior Platform Engineer</title>
    <script src="https://code.iconify.design/2/2.2.1/iconify.min.js"></script>
</head>
<body>
    <main class="resume-container">
        <Markdown content={cvContent} />
    </main>
</body>
</html>