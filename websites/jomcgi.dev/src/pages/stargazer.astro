<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stargazer</title>
    <link href='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.css' rel='stylesheet' />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Courier New', monospace;
            font-size: clamp(13px, 1vw, 16px);
            background: #fff;
            color: #000;
            overflow: hidden;
        }

        #map {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
        }

        /* Header - top left */
        .header {
            position: fixed;
            top: clamp(12px, 2vw, 24px);
            left: clamp(12px, 2vw, 24px);
            z-index: 1000;
            font-size: clamp(11px, 0.9vw, 14px);
            letter-spacing: clamp(1px, 0.2vw, 3px);
            color: #999;
            display: flex;
            align-items: center;
            gap: clamp(12px, 1.5vw, 24px);
        }

        .header-title {
            display: inline-block;
            position: relative;
            cursor: help;
        }

        /* Tooltip - follows mouse on hover */
        .tooltip {
            position: fixed;
            z-index: 1001;
            background: #fff;
            border: 2px solid #000;
            padding: clamp(12px, 1.2vw, 18px);
            pointer-events: auto;
            opacity: 0;
            transition: opacity 0.1s;
            min-width: clamp(160px, 14vw, 220px);
        }

        .tooltip.visible {
            opacity: 1;
        }

        .tooltip-coords {
            font-size: clamp(10px, 0.8vw, 13px);
            margin-bottom: clamp(6px, 0.6vw, 10px);
        }

        .tooltip-coords a {
            color: #666;
            text-decoration: none;
            border-bottom: 1px dashed #ccc;
        }

        .tooltip-coords a:hover {
            color: #000;
            border-bottom-color: #888;
        }

        .tooltip-score {
            display: flex;
            align-items: baseline;
            gap: clamp(6px, 0.6vw, 10px);
            margin-bottom: clamp(6px, 0.6vw, 10px);
        }

        .tooltip-score-value {
            font-size: clamp(20px, 1.8vw, 28px);
            font-weight: bold;
            color: #000;
        }

        .tooltip-score-label {
            font-size: clamp(9px, 0.7vw, 12px);
            color: #666;
        }

        .tooltip-details {
            font-size: clamp(10px, 0.8vw, 13px);
            color: #666;
            line-height: 1.6;
        }

        .tooltip-windows {
            margin-top: clamp(8px, 0.8vw, 12px);
            padding-top: clamp(8px, 0.8vw, 12px);
            border-top: 2px solid #ccc;
            color: #000;
            font-size: clamp(10px, 0.8vw, 13px);
        }

        .tooltip-windows-title {
            font-size: clamp(9px, 0.7vw, 11px);
            color: #666;
            margin-bottom: clamp(4px, 0.4vw, 6px);
            letter-spacing: 1px;
        }

        .tooltip-window {
            display: flex;
            justify-content: space-between;
            padding: clamp(2px, 0.2vw, 4px) 0;
        }

        .tooltip-window-time {
            color: #000;
        }

        .tooltip-window-score {
            color: #666;
        }

        /* Score colors */
        .score-exceptional { color: #090; }
        .score-good { color: #333; }
        .score-ok { color: #666; }

        /* Status - bottom left */
        .status {
            position: fixed;
            bottom: clamp(12px, 2vw, 24px);
            left: clamp(12px, 2vw, 24px);
            z-index: 1000;
            font-size: clamp(9px, 0.7vw, 12px);
            color: #333;
        }

        #updated {
            color: #000;
        }

        .attribution {
            color: #999;
        }

        .status a {
            color: #999;
            text-decoration: none;
        }

        .status a:hover {
            color: #000;
        }

        /* Hide maplibre controls we don't need */
        .maplibregl-ctrl-attrib {
            display: none;
        }

        /* Header tooltip */
        .header-tooltip {
            position: absolute;
            top: 100%;
            left: 0;
            margin-top: clamp(8px, 0.8vw, 16px);
            width: clamp(220px, 20vw, 320px);
            padding: clamp(12px, 1.2vw, 20px);
            background: #fff;
            border: 2px solid #000;
            font-size: clamp(10px, 0.8vw, 13px);
            line-height: 1.6;
            letter-spacing: 0;
            color: #555;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: opacity 0.1s, visibility 0.1s;
            z-index: 1002;
        }

        .header-title:hover .header-tooltip {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }

        .header-tooltip strong {
            color: #000;
            display: block;
            margin-bottom: clamp(6px, 0.6vw, 10px);
            font-size: clamp(9px, 0.7vw, 12px);
            letter-spacing: clamp(0.5px, 0.1vw, 2px);
        }
    </style>
</head>
<body>
    <div id="map"></div>

    <div class="header">
        <div class="header-title">STARGAZER
            <div class="header-tooltip">
                <strong>DARK SKY FINDER</strong>
                Low light pollution locations scored by weather conditions:<br><br>
                • Cloud cover (50%)<br>
                • Humidity & dew risk (30%)<br>
                • Wind & fog (20%)<br>
                • High pressure bonus<br><br>
                Green markers = exceptional (90+).<br>
                Times shown in UK timezone.<br>
                Updated every 30 min via MET Norway.
            </div>
        </div>
    </div>

    <div class="tooltip" id="tooltip">
        <div class="tooltip-coords"><a id="t-coords" href="#" target="_blank">56.6°N 6.6°W</a></div>
        <div class="tooltip-score">
            <span class="tooltip-score-value" id="t-score">95</span>
            <span class="tooltip-score-label">/ 100</span>
        </div>
        <div class="tooltip-details">
            <div>Zone <span id="t-zone">0</span></div>
            <div>Cloud <span id="t-cloud">5%</span></div>
            <div>Wind <span id="t-wind">4.2 m/s</span></div>
        </div>
        <div class="tooltip-windows" id="t-windows">
            <div class="tooltip-windows-title">CLEAR WINDOWS</div>
            <div id="t-windows-list"></div>
        </div>
    </div>

    <div class="status">
        <span id="status">Loading...</span>
        <span id="updated"></span>
        <span class="attribution">· © <a href="https://carto.com/attributions" target="_blank">CARTO</a> © <a href="https://www.openstreetmap.org/copyright" target="_blank">OSM</a></span>
    </div>

    <script is:inline src='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.js'></script>
    <script is:inline>
        const API_URL = 'https://api.jomcgi.dev/stargazer/best';
        const MIN_SCORE = 80;
        const lightTilesUrl = 'https://basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png';

        let locations = [];

        const tooltip = document.getElementById('tooltip');
        const status = document.getElementById('status');
        const updated = document.getElementById('updated');

        // Format relative time for "updated X ago"
        function formatRelativeTime(date) {
            const now = new Date();
            const diffMs = now - date;
            const diffMin = Math.floor(diffMs / 60000);
            if (diffMin < 1) return 'just now';
            if (diffMin < 60) return `${diffMin}m ago`;
            const diffHr = Math.floor(diffMin / 60);
            if (diffHr < 24) return `${diffHr}h ago`;
            return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
        }

        // Format coordinates
        function formatCoords(lat, lon) {
            const latDir = lat >= 0 ? 'N' : 'S';
            const lonDir = lon >= 0 ? 'E' : 'W';
            return `${Math.abs(lat).toFixed(1)}°${latDir} ${Math.abs(lon).toFixed(1)}°${lonDir}`;
        }

        // Format time for display (in UK timezone since locations are in Scotland)
        // Shows "HH:MM" for today, "Thu HH:MM" for other days
        function formatTimeShort(date) {
            const timeStr = date.toLocaleTimeString('en-GB', {
                hour: '2-digit',
                minute: '2-digit',
                timeZone: 'Europe/London'
            });

            // Get today's date in UK timezone
            const ukNow = new Date().toLocaleDateString('en-GB', { timeZone: 'Europe/London' });
            const ukDate = date.toLocaleDateString('en-GB', { timeZone: 'Europe/London' });

            if (ukDate === ukNow) {
                return timeStr;
            }

            // Show day name for other days
            const dayName = date.toLocaleDateString('en-GB', {
                weekday: 'short',
                timeZone: 'Europe/London'
            });
            return `${dayName} ${timeStr}`;
        }

        // Map setup
        const map = new maplibregl.Map({
            container: 'map',
            style: {
                version: 8,
                sources: {
                    'carto': {
                        type: 'raster',
                        tiles: [lightTilesUrl],
                        tileSize: 256
                    }
                },
                layers: [{
                    id: 'carto',
                    type: 'raster',
                    source: 'carto',
                    paint: {
                        'raster-saturation': -0.5
                    }
                }]
            },
            center: [-4.5, 56.8],
            zoom: 6.5
        });

        // Add markers using native MapLibre layer
        function renderMarkers() {
            const filtered = locations.filter(loc => loc.score >= MIN_SCORE && loc.windows.length > 0);
            console.log('Rendering', filtered.length, 'markers');

            // Build GeoJSON
            const geojson = {
                type: 'FeatureCollection',
                features: filtered.map(loc => ({
                    type: 'Feature',
                    geometry: {
                        type: 'Point',
                        coordinates: [loc.lon, loc.lat]
                    },
                    properties: {
                        id: loc.id,
                        score: loc.score,
                        zone: loc.zone,
                        cloud: loc.cloud,
                        wind: loc.wind,
                        windows: JSON.stringify(loc.windows),
                        exceptional: loc.score >= 90
                    }
                }))
            };

            // Update or create source
            if (map.getSource('locations')) {
                map.getSource('locations').setData(geojson);
            } else {
                map.addSource('locations', {
                    type: 'geojson',
                    data: geojson
                });

                // Add circle layer for all points - colored by score
                map.addLayer({
                    id: 'locations-circle',
                    type: 'circle',
                    source: 'locations',
                    paint: {
                        'circle-radius': [
                            'case',
                            ['>=', ['get', 'score'], 90], 8,
                            ['>=', ['get', 'score'], 80], 7,
                            6
                        ],
                        'circle-color': [
                            'case',
                            ['>=', ['get', 'score'], 90], '#090',
                            ['>=', ['get', 'score'], 80], '#4a0',
                            ['>=', ['get', 'score'], 70], '#880',
                            '#a50'
                        ],
                        'circle-stroke-width': 1,
                        'circle-stroke-color': '#fff',
                        'circle-opacity': 0.9
                    }
                });

                // Add glow layer for exceptional points
                map.addLayer({
                    id: 'locations-glow',
                    type: 'circle',
                    source: 'locations',
                    filter: ['==', ['get', 'exceptional'], true],
                    paint: {
                        'circle-radius': 16,
                        'circle-color': '#090',
                        'circle-opacity': 0.2,
                        'circle-blur': 1
                    }
                }, 'locations-circle');

                // Set up hover handlers
                let hideTimeout;

                map.on('mouseenter', 'locations-circle', (e) => {
                    clearTimeout(hideTimeout);
                    map.getCanvas().style.cursor = 'pointer';
                    if (e.features.length > 0) {
                        const props = e.features[0].properties;
                        const coords = e.features[0].geometry.coordinates;
                        const lat = coords[1];
                        const lon = coords[0];

                        const coordsEl = document.getElementById('t-coords');
                        coordsEl.textContent = formatCoords(lat, lon);
                        coordsEl.href = `https://www.google.com/maps?q=${lat},${lon}`;

                        const scoreEl = document.getElementById('t-score');
                        scoreEl.textContent = props.score;
                        scoreEl.className = 'tooltip-score-value ' +
                            (props.score >= 90 ? 'score-exceptional' : props.score >= 75 ? 'score-good' : 'score-ok');

                        document.getElementById('t-zone').textContent = props.zone;
                        document.getElementById('t-cloud').textContent = props.cloud + '%';
                        document.getElementById('t-wind').textContent = props.wind + ' m/s';

                        // Show windows
                        const windows = JSON.parse(props.windows);
                        const windowsEl = document.getElementById('t-windows');
                        const windowsListEl = document.getElementById('t-windows-list');

                        if (windows.length > 0) {
                            windowsListEl.innerHTML = windows.map(w =>
                                `<div class="tooltip-window">
                                    <span class="tooltip-window-time">${w.time}</span>
                                    <span class="tooltip-window-score">${w.score}</span>
                                </div>`
                            ).join('');
                            windowsEl.style.display = 'block';
                        } else {
                            windowsEl.style.display = 'none';
                        }

                        tooltip.classList.add('visible');
                    }
                });

                map.on('mousemove', 'locations-circle', (e) => {
                    tooltip.style.left = (e.originalEvent.clientX + 16) + 'px';
                    tooltip.style.top = (e.originalEvent.clientY + 16) + 'px';
                });

                map.on('mouseleave', 'locations-circle', () => {
                    map.getCanvas().style.cursor = '';
                    // Delay hiding so user can move to tooltip
                    hideTimeout = setTimeout(() => {
                        tooltip.classList.remove('visible');
                    }, 100);
                });

                // Keep tooltip visible when hovering it
                tooltip.addEventListener('mouseenter', () => {
                    clearTimeout(hideTimeout);
                });

                tooltip.addEventListener('mouseleave', () => {
                    tooltip.classList.remove('visible');
                });
            }

            status.textContent = `${filtered.length} locations`;
        }

        // Fetch data and schedule refresh
        let refreshTimer = null;

        async function fetchLocations() {
            try {
                const res = await fetch(API_URL);
                if (res.ok) {
                    // Show when data was last updated
                    const lastModified = res.headers.get('last-modified');
                    if (lastModified) {
                        const updateDate = new Date(lastModified);
                        updated.textContent = `· updated ${formatRelativeTime(updateDate)}`;
                    }

                    // Schedule refresh when new data is expected
                    const nextUpdate = res.headers.get('x-next-update');
                    if (nextUpdate) {
                        const nextUpdateMs = parseInt(nextUpdate, 10);
                        const delayMs = Math.max(60000, nextUpdateMs - Date.now() + 5000); // +5s buffer
                        if (refreshTimer) clearTimeout(refreshTimer);
                        refreshTimer = setTimeout(fetchLocations, delayMs);
                        console.log(`Next refresh in ${Math.round(delayMs / 60000)}m`);
                    }

                    const data = await res.json();
                    const now = new Date();

                    locations = data
                        .map(loc => {
                            const lat = loc.coordinates?.lat;
                            const lon = loc.coordinates?.lon;
                            if (typeof lat !== 'number' || typeof lon !== 'number') return null;

                            // Filter to future hours only and sort chronologically
                            const futureHours = (loc.best_hours || [])
                                .filter(h => new Date(h.time) > now)
                                .sort((a, b) => new Date(a.time) - new Date(b.time))
                                .slice(0, 5);

                            if (futureHours.length === 0) return null;

                            // Best score is the highest among remaining future hours
                            const best = futureHours.reduce((max, h) =>
                                h.score > max.score ? h : max, futureHours[0]);

                            return {
                                id: loc.id,
                                lat, lon,
                                zone: loc.lp_zone || '?',
                                score: Math.round(best.score || 0),
                                cloud: Math.round(best.cloud_area_fraction || 0),
                                wind: best.wind_speed?.toFixed(1) || '?',
                                windows: futureHours.map(h => ({
                                    time: formatTimeShort(new Date(h.time)),
                                    score: Math.round(h.score)
                                }))
                            };
                        })
                        .filter(Boolean);
                } else {
                    locations = [];
                    // Retry in 5 minutes on error
                    if (refreshTimer) clearTimeout(refreshTimer);
                    refreshTimer = setTimeout(fetchLocations, 300000);
                }
            } catch {
                locations = [];
                // Retry in 5 minutes on error
                if (refreshTimer) clearTimeout(refreshTimer);
                refreshTimer = setTimeout(fetchLocations, 300000);
            }
            renderMarkers();
        }

        map.on('load', fetchLocations);
    </script>
</body>
</html>
