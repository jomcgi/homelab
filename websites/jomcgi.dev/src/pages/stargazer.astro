<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stargazer</title>
    <link href='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.css' rel='stylesheet' />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Courier New', monospace;
            font-size: clamp(13px, 1vw, 16px);
            background: #000;
            color: #fff;
            overflow: hidden;
        }

        #map {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
        }

        /* Header - top left */
        .header {
            position: fixed;
            top: clamp(12px, 2vw, 24px);
            left: clamp(12px, 2vw, 24px);
            z-index: 1000;
            font-size: clamp(11px, 0.9vw, 14px);
            letter-spacing: clamp(1px, 0.2vw, 3px);
            color: #666;
            display: flex;
            align-items: center;
            gap: clamp(12px, 1.5vw, 24px);
        }

        .header-title {
            display: inline-block;
            position: relative;
        }

        /* Filters - top right */
        .filters {
            position: fixed;
            top: clamp(12px, 2vw, 24px);
            right: clamp(12px, 2vw, 24px);
            z-index: 1000;
        }

        .filter-btn {
            background: #000;
            border: 2px solid #666;
            color: #888;
            padding: clamp(6px, 0.6vw, 12px) clamp(12px, 1.2vw, 24px);
            font-family: inherit;
            font-size: clamp(10px, 0.8vw, 14px);
            cursor: pointer;
            transition: all 0.1s;
            min-width: clamp(70px, 6vw, 100px);
        }

        .filter-btn:hover {
            color: #fff;
            border-color: #fff;
        }

        .filter-btn.active {
            background: #fff;
            color: #000;
            border: 2px solid #fff;
        }

        /* Invert button - inline with header */
        .invert-btn {
            position: relative;
            z-index: 1;
            background: #000;
            border: 2px solid #666;
            color: #888;
            padding: clamp(4px, 0.4vw, 8px) clamp(8px, 0.8vw, 16px);
            font-family: inherit;
            font-size: clamp(9px, 0.7vw, 12px);
            cursor: pointer;
            transition: all 0.1s;
            letter-spacing: clamp(0.5px, 0.1vw, 2px);
        }

        .invert-btn:hover {
            color: #fff;
            border-color: #fff;
        }

        /* Inverted mode */
        body.inverted {
            background: #fff;
        }

        body.inverted .header {
            color: #999;
        }

        body.inverted .filter-btn {
            background: #fff;
            border: 2px solid #999;
            color: #666;
        }

        body.inverted .filter-btn:hover {
            color: #000;
            border-color: #000;
        }

        body.inverted .filter-btn.active {
            background: #000;
            color: #fff;
            border: 2px solid #000;
        }

        body.inverted .invert-btn {
            background: #fff;
            border: 2px solid #999;
            color: #666;
        }

        body.inverted .invert-btn:hover {
            color: #000;
            border-color: #000;
        }

        body.inverted .tooltip {
            background: #fff;
            border: 2px solid #000;
        }

        body.inverted .tooltip-coords a {
            color: #666;
            border-bottom-color: #ccc;
        }

        body.inverted .tooltip-coords a:hover {
            color: #000;
        }

        body.inverted .tooltip-score-value {
            color: #000;
        }

        body.inverted .tooltip-details {
            color: #666;
        }

        body.inverted .tooltip-time {
            color: #000;
            border-top: 2px solid #ccc;
        }

        body.inverted .status {
            color: #333;
        }

        body.inverted .score-exceptional { color: #090; }
        body.inverted .score-good { color: #333; }
        body.inverted .score-ok { color: #666; }

        /* Tooltip - follows mouse on hover */
        .tooltip {
            position: fixed;
            z-index: 1001;
            background: #000;
            border: 2px solid #fff;
            padding: clamp(12px, 1.2vw, 18px);
            pointer-events: auto;
            opacity: 0;
            transition: opacity 0.1s;
            min-width: clamp(160px, 14vw, 220px);
        }

        .tooltip.visible {
            opacity: 1;
        }

        .tooltip-coords {
            font-size: clamp(10px, 0.8vw, 13px);
            margin-bottom: clamp(6px, 0.6vw, 10px);
        }

        .tooltip-coords a {
            color: #888;
            text-decoration: none;
            border-bottom: 1px dashed #444;
        }

        .tooltip-coords a:hover {
            color: #fff;
            border-bottom-color: #888;
        }

        .tooltip-score {
            display: flex;
            align-items: baseline;
            gap: clamp(6px, 0.6vw, 10px);
            margin-bottom: clamp(6px, 0.6vw, 10px);
        }

        .tooltip-score-value {
            font-size: clamp(20px, 1.8vw, 28px);
            font-weight: bold;
        }

        .tooltip-score-label {
            font-size: clamp(9px, 0.7vw, 12px);
            color: #666;
        }

        .tooltip-details {
            font-size: clamp(10px, 0.8vw, 13px);
            color: #888;
            line-height: 1.6;
        }

        .tooltip-time {
            margin-top: clamp(8px, 0.8vw, 12px);
            padding-top: clamp(8px, 0.8vw, 12px);
            border-top: 2px solid #444;
            color: #fff;
        }

        /* Markers - now handled by MapLibre layer */
        
        /* Only exceptional spots get color - handled in layer paint */

        .marker.exceptional:hover {
            box-shadow: 0 0 16px #0f0;
        }

        /* Score color in tooltip */
        .score-exceptional { color: #0f0; }
        .score-good { color: #fff; }
        .score-ok { color: #888; }

        /* Status - bottom left */
        .status {
            position: fixed;
            bottom: clamp(12px, 2vw, 24px);
            left: clamp(12px, 2vw, 24px);
            z-index: 1000;
            font-size: clamp(9px, 0.7vw, 12px);
            color: #ccc;
        }

        #updated {
            color: #fff;
        }

        body.inverted #updated {
            color: #000;
        }

        .attribution {
            color: #666;
        }

        body.inverted .attribution {
            color: #999;
        }

        .status a {
            color: #666;
            text-decoration: none;
        }

        .status a:hover {
            color: #fff;
        }

        body.inverted .status a {
            color: #999;
        }

        body.inverted .status a:hover {
            color: #000;
        }

        /* Hide maplibre controls we don't need */
        .maplibregl-ctrl-attrib {
            display: none;
        }

        /* Header tooltip */
        .header-title {
            position: relative;
            cursor: help;
        }

        .header-tooltip {
            position: absolute;
            top: 100%;
            left: 0;
            margin-top: clamp(8px, 0.8vw, 16px);
            width: clamp(220px, 20vw, 320px);
            padding: clamp(12px, 1.2vw, 20px);
            background: #000;
            border: 2px solid #fff;
            font-size: clamp(10px, 0.8vw, 13px);
            line-height: 1.6;
            letter-spacing: 0;
            color: #aaa;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: opacity 0.1s, visibility 0.1s;
            z-index: 1002;
        }

        .header-title:hover .header-tooltip {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }

        .header-tooltip strong {
            color: #fff;
            display: block;
            margin-bottom: clamp(6px, 0.6vw, 10px);
            font-size: clamp(9px, 0.7vw, 12px);
            letter-spacing: clamp(0.5px, 0.1vw, 2px);
        }

        body.inverted .header-tooltip {
            background: #fff;
            border-color: #000;
            color: #555;
        }

        body.inverted .header-tooltip strong {
            color: #000;
        }
    </style>
    <script>
        // Theme: check localStorage first, then system preference
        // Note: stargazer defaults to dark, so "inverted" = light mode
        (function() {
            const stored = localStorage.getItem('darkMode');
            if (stored === 'false') {
                // User explicitly chose light mode
                document.documentElement.classList.add('light-pending');
            } else if (stored === 'true') {
                // User explicitly chose dark mode - stargazer default
            } else if (!window.matchMedia('(prefers-color-scheme: dark)').matches) {
                // No preference, system is light
                document.documentElement.classList.add('light-pending');
            }
        })();
    </script>
</head>
<body>
    <script>
        // Apply theme immediately to avoid flash
        // Stargazer defaults to dark, so light-pending = inverted mode
        if (document.documentElement.classList.contains('light-pending')) {
            document.body.classList.add('inverted');
            document.documentElement.classList.remove('light-pending');
        }
    </script>
    <div id="map"></div>

    <div class="header">
        <span class="header-title">STARGAZER
            <div class="header-tooltip">
                <strong>DARK SKY FINDER</strong>
                Locations scored by light pollution zone, road accessibility, and weather forecast.
                Green markers indicate exceptional conditions (90+).
                Data updates hourly from MET Norway.
            </div>
        </span>
        <button class="invert-btn" id="invert-btn">INVERT</button>
    </div>

    <div class="filters">
        <button class="filter-btn active" id="tonight-btn">TONIGHT</button>
    </div>

    <div class="tooltip" id="tooltip">
        <div class="tooltip-coords"><a id="t-coords" href="#" target="_blank">56.6°N 6.6°W</a></div>
        <div class="tooltip-score">
            <span class="tooltip-score-value" id="t-score">95</span>
            <span class="tooltip-score-label">/ 100</span>
        </div>
        <div class="tooltip-details">
            <div>Zone <span id="t-zone">0</span></div>
            <div>Cloud <span id="t-cloud">5%</span></div>
            <div>Wind <span id="t-wind">4.2 m/s</span></div>
        </div>
        <div class="tooltip-time" id="t-time">Clear from 21:30</div>
    </div>

    <div class="status">
        <span id="status">Loading...</span>
        <span id="updated"></span>
        <span class="attribution">· © <a href="https://carto.com/attributions" target="_blank">CARTO</a> © <a href="https://www.openstreetmap.org/copyright" target="_blank">OSM</a></span>
    </div>

    <script src='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.js'></script>
    <script>
        // Invert button - works independently of map
        let mapInstance = null;
        const darkTilesUrl = 'https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}@2x.png';
        const lightTilesUrl = 'https://basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png';

        document.addEventListener('DOMContentLoaded', () => {
            const invertBtn = document.getElementById('invert-btn');
            invertBtn.addEventListener('click', () => {
                document.body.classList.toggle('inverted');
                const isInverted = document.body.classList.contains('inverted');

                // Swap tile source for map
                if (mapInstance && mapInstance.getSource('carto')) {
                    mapInstance.getSource('carto').setTiles([isInverted ? lightTilesUrl : darkTilesUrl]);
                }

                // Save preference - stargazer inverted = light mode = darkMode false
                localStorage.setItem('darkMode', isInverted ? 'false' : 'true');
            });

            // Initialize map
            init();
        });

        function init() {
        const API_URL = 'https://api.jomcgi.dev/stargazer/best';
        
        // Demo data fallback
        const demoLocations = [
            { id: '1', lat: 56.6189, lon: -6.5572, zone: '0', score: 95, cloud: 5, wind: 4.2, time: 'Tonight 21:30' },
            { id: '2', lat: 55.0833, lon: -4.5000, zone: '1a', score: 92, cloud: 8, wind: 2.8, time: 'Tonight 22:00' },
            { id: '3', lat: 58.3500, lon: -4.7500, zone: '0', score: 88, cloud: 12, wind: 3.2, time: 'Tonight 22:30' },
            { id: '4', lat: 57.0488, lon: -3.6106, zone: '1b', score: 87, cloud: 15, wind: 3.5, time: 'Tonight 23:00' },
            { id: '5', lat: 57.6433, lon: -6.2653, zone: '1a', score: 78, cloud: 25, wind: 5.1, time: 'Tomorrow 02:00' },
            { id: '6', lat: 56.8, lon: -5.1, zone: '1b', score: 72, cloud: 30, wind: 3.8, time: 'Tomorrow 01:00' },
            { id: '7', lat: 55.5, lon: -5.5, zone: '2', score: 65, cloud: 35, wind: 4.5, time: 'Tomorrow 03:00' },
            { id: '8', lat: 57.2, lon: -4.2, zone: '1a', score: 81, cloud: 18, wind: 2.9, time: 'Tonight 23:30' },
        ];

        let locations = [];
        let tonightOnly = true; // Default: show tonight only
        const MIN_SCORE = 80; // Always show 80+ only

        const tooltip = document.getElementById('tooltip');
        const status = document.getElementById('status');
        const updated = document.getElementById('updated');

        // Format relative time for "updated X ago"
        function formatRelativeTime(date) {
            const now = new Date();
            const diffMs = now - date;
            const diffMin = Math.floor(diffMs / 60000);
            if (diffMin < 1) return 'just now';
            if (diffMin < 60) return `${diffMin}m ago`;
            const diffHr = Math.floor(diffMin / 60);
            if (diffHr < 24) return `${diffHr}h ago`;
            return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
        }

        // Format coordinates
        function formatCoords(lat, lon) {
            const latDir = lat >= 0 ? 'N' : 'S';
            const lonDir = lon >= 0 ? 'E' : 'W';
            return `${Math.abs(lat).toFixed(1)}°${latDir} ${Math.abs(lon).toFixed(1)}°${lonDir}`;
        }

        // Format time
        function formatTime(isoString) {
            if (!isoString) return null;
            const date = new Date(isoString);
            const now = new Date();
            const tomorrow = new Date(now);
            tomorrow.setDate(tomorrow.getDate() + 1);
            const timeStr = date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
            if (date.toDateString() === now.toDateString()) return `Tonight ${timeStr}`;
            if (date.toDateString() === tomorrow.toDateString()) return `Tomorrow ${timeStr}`;
            return date.toLocaleDateString('en-GB', { weekday: 'short' }) + ` ${timeStr}`;
        }

        // Map setup - check if starting in inverted mode
        const startInverted = document.body.classList.contains('inverted');

        const map = mapInstance = new maplibregl.Map({
            container: 'map',
            style: {
                version: 8,
                sources: {
                    'carto': {
                        type: 'raster',
                        tiles: [startInverted ? lightTilesUrl : darkTilesUrl],
                        tileSize: 256
                    }
                },
                layers: [{
                    id: 'carto',
                    type: 'raster',
                    source: 'carto',
                    paint: {
                        'raster-saturation': -0.5
                    }
                }]
            },
            center: [-4.5, 56.8],
            zoom: 6.5
        });

        // Add markers using native MapLibre layer
        function renderMarkers() {
            const filtered = locations.filter(loc => loc.score >= MIN_SCORE);
            console.log('Rendering', filtered.length, 'markers');

            // Build GeoJSON
            const geojson = {
                type: 'FeatureCollection',
                features: filtered.map(loc => ({
                    type: 'Feature',
                    geometry: {
                        type: 'Point',
                        coordinates: [loc.lon, loc.lat]
                    },
                    properties: {
                        id: loc.id,
                        score: loc.score,
                        zone: loc.zone,
                        cloud: loc.cloud,
                        wind: loc.wind,
                        time: loc.time,
                        exceptional: loc.score >= 90
                    }
                }))
            };

            // Update or create source
            if (map.getSource('locations')) {
                map.getSource('locations').setData(geojson);
            } else {
                map.addSource('locations', {
                    type: 'geojson',
                    data: geojson
                });

                // Add circle layer for all points - colored by score
                map.addLayer({
                    id: 'locations-circle',
                    type: 'circle',
                    source: 'locations',
                    paint: {
                        'circle-radius': [
                            'case',
                            ['>=', ['get', 'score'], 90], 8,
                            ['>=', ['get', 'score'], 80], 7,
                            6
                        ],
                        'circle-color': [
                            'case',
                            ['>=', ['get', 'score'], 90], '#0f0',
                            ['>=', ['get', 'score'], 80], '#8f0',
                            ['>=', ['get', 'score'], 70], '#ff0',
                            '#f80'
                        ],
                        'circle-stroke-width': 1,
                        'circle-stroke-color': '#fff',
                        'circle-opacity': 0.9
                    }
                });

                // Add glow layer for exceptional points
                map.addLayer({
                    id: 'locations-glow',
                    type: 'circle',
                    source: 'locations',
                    filter: ['==', ['get', 'exceptional'], true],
                    paint: {
                        'circle-radius': 16,
                        'circle-color': '#0f0',
                        'circle-opacity': 0.2,
                        'circle-blur': 1
                    }
                }, 'locations-circle');

                // Set up hover handlers
                let hideTimeout;
                
                map.on('mouseenter', 'locations-circle', (e) => {
                    clearTimeout(hideTimeout);
                    map.getCanvas().style.cursor = 'pointer';
                    if (e.features.length > 0) {
                        const props = e.features[0].properties;
                        const coords = e.features[0].geometry.coordinates;
                        const lat = coords[1];
                        const lon = coords[0];
                        
                        const coordsEl = document.getElementById('t-coords');
                        coordsEl.textContent = formatCoords(lat, lon);
                        coordsEl.href = `https://www.google.com/maps?q=${lat},${lon}`;
                        
                        const scoreEl = document.getElementById('t-score');
                        scoreEl.textContent = props.score;
                        scoreEl.className = 'tooltip-score-value ' + 
                            (props.score >= 90 ? 'score-exceptional' : props.score >= 75 ? 'score-good' : 'score-ok');

                        document.getElementById('t-zone').textContent = props.zone;
                        document.getElementById('t-cloud').textContent = props.cloud + '%';
                        document.getElementById('t-wind').textContent = props.wind + ' m/s';
                        document.getElementById('t-time').textContent = props.time ? `Clear from ${props.time.split(' ').pop()}` : 'Check forecast';

                        tooltip.classList.add('visible');
                    }
                });

                map.on('mousemove', 'locations-circle', (e) => {
                    tooltip.style.left = (e.originalEvent.clientX + 16) + 'px';
                    tooltip.style.top = (e.originalEvent.clientY + 16) + 'px';
                });
                
                map.on('mouseleave', 'locations-circle', () => {
                    map.getCanvas().style.cursor = '';
                    // Delay hiding so user can move to tooltip
                    hideTimeout = setTimeout(() => {
                        tooltip.classList.remove('visible');
                    }, 100);
                });

                // Keep tooltip visible when hovering it
                tooltip.addEventListener('mouseenter', () => {
                    clearTimeout(hideTimeout);
                });

                tooltip.addEventListener('mouseleave', () => {
                    tooltip.classList.remove('visible');
                });
            }

            status.textContent = `${filtered.length} locations`;
        }

        // Tonight toggle - simple on/off
        const tonightBtn = document.getElementById('tonight-btn');
        tonightBtn.addEventListener('click', () => {
            tonightOnly = !tonightOnly;
            tonightBtn.classList.toggle('active', tonightOnly);
            tonightBtn.textContent = tonightOnly ? 'TONIGHT' : '72H';
            // Would refetch with different time range in production
            renderMarkers();
        });

        // Fetch data
        async function fetchLocations() {
            try {
                const res = await fetch(API_URL);
                if (res.ok) {
                    // Show when data was last updated
                    const lastModified = res.headers.get('last-modified');
                    if (lastModified) {
                        const updateDate = new Date(lastModified);
                        updated.textContent = `· updated ${formatRelativeTime(updateDate)}`;
                    }

                    const data = await res.json();
                    locations = data
                        .map(loc => {
                            const lat = loc.coordinates?.lat;
                            const lon = loc.coordinates?.lon;
                            if (typeof lat !== 'number' || typeof lon !== 'number') return null;
                            const best = loc.best_hours?.[0] || {};
                            return {
                                id: loc.id,
                                lat, lon,
                                zone: loc.lp_zone || '?',
                                score: Math.round(loc.best_score || 0),
                                cloud: Math.round(best.cloud_area_fraction || 0),
                                wind: best.wind_speed?.toFixed(1) || '?',
                                time: formatTime(best.time)
                            };
                        })
                        .filter(Boolean);
                } else {
                    locations = demoLocations;
                }
            } catch {
                locations = demoLocations;
            }
            renderMarkers();
        }

        map.on('load', fetchLocations);
        }
    </script>
</body>
</html>