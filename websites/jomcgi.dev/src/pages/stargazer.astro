---
import { ViewTransitions } from 'astro:transitions';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Stargazer - Dark Sky Scotland</title>
    <ViewTransitions />

    <!-- MapLibre GL CSS -->
    <link href='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.css' rel='stylesheet' />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            line-height: 1.6;
            background: #000;
            color: #fff;
            overflow: hidden;
        }

        #app {
            height: 100vh;
            display: grid;
            grid-template-columns: 400px 1fr;
        }

        /* Sidebar */
        .sidebar {
            background: #111;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            padding: 20px;
            border-bottom: 1px solid #333;
        }

        .header h1 {
            font-size: 24px;
            font-weight: normal;
            margin-bottom: 8px;
        }

        .header .subtitle {
            color: #888;
            font-size: 12px;
        }

        /* Status indicators */
        .status-bar {
            display: flex;
            gap: 20px;
            padding: 15px 20px;
            background: #0a0a0a;
            border-bottom: 1px solid #333;
            font-size: 12px;
        }

        .status-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #444;
        }

        .status-indicator.active {
            background: #0f0;
            box-shadow: 0 0 8px #0f0;
        }

        /* Location list */
        .locations {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .location-card {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 4px;
            padding: 15px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .location-card:hover {
            background: #222;
            border-color: #0f0;
            transform: translateX(5px);
        }

        .location-card.selected {
            background: #0a2a0a;
            border-color: #0f0;
        }

        .location-name {
            font-weight: bold;
            margin-bottom: 8px;
            color: #0f0;
        }

        .location-meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            font-size: 12px;
            color: #888;
        }

        .location-score {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
        }

        .score-bar {
            flex: 1;
            height: 4px;
            background: #333;
            border-radius: 2px;
            overflow: hidden;
        }

        .score-fill {
            height: 100%;
            background: linear-gradient(90deg, #f00, #ff0, #0f0);
            transition: width 0.3s;
        }

        /* Map container */
        #map {
            position: relative;
            width: 100%;
            height: 100%;
            background: #0a0a0a;
        }

        /* Map controls overlay */
        .map-controls {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.9);
            border: 1px solid #333;
            border-radius: 4px;
            padding: 10px;
            z-index: 1000;
        }

        .control-group {
            margin-bottom: 15px;
        }

        .control-group:last-child {
            margin-bottom: 0;
        }

        .control-label {
            font-size: 11px;
            color: #888;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .control-buttons {
            display: flex;
            gap: 5px;
        }

        .control-btn {
            padding: 5px 10px;
            background: #222;
            border: 1px solid #444;
            color: #fff;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }

        .control-btn:hover {
            background: #333;
            border-color: #0f0;
        }

        .control-btn.active {
            background: #0a2a0a;
            border-color: #0f0;
            color: #0f0;
        }

        /* Loading state */
        .loading {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            font-size: 14px;
            color: #888;
        }

        .loading::after {
            content: '';
            animation: dots 1.5s infinite;
        }

        @keyframes dots {
            0%, 20% { content: ''; }
            40% { content: '.'; }
            60% { content: '..'; }
            80%, 100% { content: '...'; }
        }

        /* Light pollution legend */
        .legend {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background: rgba(0, 0, 0, 0.9);
            border: 1px solid #333;
            border-radius: 4px;
            padding: 10px;
            font-size: 11px;
        }

        .legend-title {
            color: #888;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
        }

        .legend-color {
            width: 20px;
            height: 12px;
            border: 1px solid #444;
        }

        /* Mobile responsive */
        @media (max-width: 768px) {
            #app {
                grid-template-columns: 1fr;
                grid-template-rows: 1fr 1fr;
            }

            .sidebar {
                border-right: none;
                border-bottom: 1px solid #333;
            }

            .map-controls, .legend {
                transform: scale(0.9);
            }
        }

        /* Custom marker styles */
        .marker {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid #0f0;
            background: rgba(0, 255, 0, 0.3);
            cursor: pointer;
            transition: all 0.2s;
        }

        .marker:hover {
            transform: scale(1.5);
            background: rgba(0, 255, 0, 0.6);
            box-shadow: 0 0 20px #0f0;
        }

        .marker.selected {
            background: #0f0;
            box-shadow: 0 0 30px #0f0;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }
    </style>
</head>
<body>
    <div id="app">
        <div class="sidebar">
            <div class="header">
                <h1>STARGAZER</h1>
                <div class="subtitle">Dark Sky Locations • Scotland</div>
            </div>

            <div class="status-bar">
                <div class="status-item">
                    <div class="status-indicator" id="data-status"></div>
                    <span>Data</span>
                </div>
                <div class="status-item">
                    <div class="status-indicator" id="weather-status"></div>
                    <span>Weather</span>
                </div>
                <div class="status-item">
                    <div class="status-indicator" id="forecast-status"></div>
                    <span>72h Forecast</span>
                </div>
            </div>

            <div class="locations" id="locations">
                <div class="loading">Loading locations</div>
            </div>
        </div>

        <div id="map">
            <div class="map-controls">
                <div class="control-group">
                    <div class="control-label">Time Range</div>
                    <div class="control-buttons">
                        <button class="control-btn active" data-range="tonight">Tonight</button>
                        <button class="control-btn" data-range="24h">24h</button>
                        <button class="control-btn" data-range="48h">48h</button>
                        <button class="control-btn" data-range="72h">72h</button>
                    </div>
                </div>

                <div class="control-group">
                    <div class="control-label">Min Score</div>
                    <div class="control-buttons">
                        <button class="control-btn" data-score="60">60+</button>
                        <button class="control-btn active" data-score="70">70+</button>
                        <button class="control-btn" data-score="80">80+</button>
                        <button class="control-btn" data-score="90">90+</button>
                    </div>
                </div>
            </div>

            <div class="legend">
                <div class="legend-title">Light Pollution</div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #000"></div>
                    <span>Pristine (Bortle 1)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #111"></div>
                    <span>Dark (Bortle 2)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #222"></div>
                    <span>Rural (Bortle 3)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #444"></div>
                    <span>Suburban (Bortle 4+)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- MapLibre GL JS -->
    <script src='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.js'></script>

    <script>
        // API endpoint for Stargazer data
        const API_URL = 'https://api.jomcgi.dev/stargazer/api/best';

        let locations = [];
        const mockLocations = [
            {
                id: 'galloway-1',
                name: 'Galloway Forest Dark Sky Park',
                lat: 55.0833,
                lon: -4.5000,
                altitude_m: 320,
                lp_zone: '1a',
                score: 92,
                cloud_cover: 8,
                humidity: 65,
                wind_speed: 2.8,
                next_clear: 'Tonight 22:00',
                moon_phase: 'New Moon'
            },
            {
                id: 'cairngorms-1',
                name: 'Cairngorms National Park',
                lat: 57.0488,
                lon: -3.6106,
                altitude_m: 450,
                lp_zone: '1b',
                score: 87,
                cloud_cover: 15,
                humidity: 70,
                wind_speed: 3.5,
                next_clear: 'Tonight 23:00',
                moon_phase: 'New Moon'
            },
            {
                id: 'coll-1',
                name: 'Isle of Coll',
                lat: 56.6189,
                lon: -6.5572,
                altitude_m: 25,
                lp_zone: '0',
                score: 95,
                cloud_cover: 5,
                humidity: 60,
                wind_speed: 4.2,
                next_clear: 'Tonight 21:30',
                moon_phase: 'New Moon'
            },
            {
                id: 'skye-1',
                name: 'Quiraing, Isle of Skye',
                lat: 57.6433,
                lon: -6.2653,
                altitude_m: 280,
                lp_zone: '1a',
                score: 78,
                cloud_cover: 25,
                humidity: 75,
                wind_speed: 5.1,
                next_clear: 'Tomorrow 02:00',
                moon_phase: 'New Moon'
            },
            {
                id: 'sutherland-1',
                name: 'Northwest Sutherland',
                lat: 58.3500,
                lon: -4.7500,
                altitude_m: 150,
                lp_zone: '0',
                score: 88,
                cloud_cover: 12,
                humidity: 68,
                wind_speed: 3.2,
                next_clear: 'Tonight 22:30',
                moon_phase: 'New Moon'
            }
        ];

        let map;
        let markers = [];
        let selectedLocationId = null;

        // Initialize map
        function initMap() {
            map = new maplibregl.Map({
                container: 'map',
                style: {
                    version: 8,
                    sources: {
                        'osm': {
                            type: 'raster',
                            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
                            tileSize: 256,
                            attribution: '© OpenStreetMap contributors'
                        }
                    },
                    layers: [{
                        id: 'osm',
                        type: 'raster',
                        source: 'osm',
                        paint: {
                            'raster-brightness-min': 0.2,
                            'raster-brightness-max': 0.4,
                            'raster-contrast': 0.8
                        }
                    }],
                    glyphs: 'https://fonts.openmaptiles.org/{fontstack}/{range}.pbf'
                },
                center: [-4.5, 56.5], // Center of Scotland
                zoom: 6,
                pitch: 0,
                bearing: 0
            });

            // Add navigation controls
            map.addControl(new maplibregl.NavigationControl(), 'top-left');

            // Add markers for locations
            map.on('load', () => {
                addLocationMarkers();
                updateStatus();
            });
        }

        // Add markers to map
        function addLocationMarkers() {
            // Clear existing markers
            markers.forEach(m => m.marker.remove());
            markers = [];

            locations.forEach(location => {
                const el = document.createElement('div');
                el.className = 'marker';
                el.id = `marker-${location.id}`;

                const marker = new maplibregl.Marker(el)
                    .setLngLat([location.lon, location.lat])
                    .addTo(map);

                el.addEventListener('click', () => selectLocation(location.id));

                markers.push({ marker, location });
            });
        }

        // Render location cards
        function renderLocations() {
            const container = document.getElementById('locations');
            container.innerHTML = '';

            if (locations.length === 0) {
                container.innerHTML = '<div class="loading">No locations available</div>';
                return;
            }

            locations.forEach(location => {
                const card = document.createElement('div');
                card.className = 'location-card';
                card.id = `card-${location.id}`;
                card.onclick = () => selectLocation(location.id);

                card.innerHTML = `
                    <div class="location-name">${location.name}</div>
                    <div class="location-meta">
                        <div>Zone: ${location.lp_zone}</div>
                        <div>Alt: ${location.altitude_m}m</div>
                        <div>Cloud: ${location.cloud_cover}%</div>
                        <div>Wind: ${location.wind_speed} m/s</div>
                        <div>${location.moon_phase}</div>
                        <div>${location.next_clear}</div>
                    </div>
                    <div class="location-score">
                        <span>Score: ${location.score}</span>
                        <div class="score-bar">
                            <div class="score-fill" style="width: ${location.score}%"></div>
                        </div>
                    </div>
                `;

                container.appendChild(card);
            });
        }

        // Select location
        function selectLocation(locationId) {
            // Update selected state
            selectedLocationId = locationId;

            // Update cards
            document.querySelectorAll('.location-card').forEach(card => {
                card.classList.toggle('selected', card.id === `card-${locationId}`);
            });

            // Update markers
            document.querySelectorAll('.marker').forEach(marker => {
                marker.classList.toggle('selected', marker.id === `marker-${locationId}`);
            });

            // Pan map to location
            const location = locations.find(l => l.id === locationId);
            if (location) {
                map.flyTo({
                    center: [location.lon, location.lat],
                    zoom: 10,
                    duration: 1500
                });
            }
        }

        // Fetch locations from API
        async function fetchLocations() {
            try {
                const response = await fetch(API_URL);
                if (response.ok) {
                    locations = await response.json();
                    console.log(`Loaded ${locations.length} locations from API`);
                } else {
                    console.warn('API unavailable, using demo data');
                    locations = mockLocations;
                }
            } catch (error) {
                console.error('Failed to fetch locations:', error);
                locations = mockLocations;
            }

            // Update UI
            renderLocations();
            if (map && map.loaded()) {
                addLocationMarkers();
            }
        }

        // Update status indicators
        function updateStatus() {
            document.getElementById('data-status').classList.add('active');
            setTimeout(() => {
                document.getElementById('weather-status').classList.add('active');
            }, 500);
            setTimeout(() => {
                document.getElementById('forecast-status').classList.add('active');
            }, 1000);
        }

        // Handle control buttons
        document.addEventListener('DOMContentLoaded', async () => {
            // Initialize map
            initMap();

            // Fetch and render locations
            await fetchLocations();

            // Time range controls
            document.querySelectorAll('[data-range]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('[data-range]').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    // TODO: Filter locations by time range
                });
            });

            // Score filter controls
            document.querySelectorAll('[data-score]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('[data-score]').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    const minScore = parseInt(e.target.dataset.score);
                    // TODO: Filter locations by minimum score
                });
            });
        });
    </script>
</body>
</html>