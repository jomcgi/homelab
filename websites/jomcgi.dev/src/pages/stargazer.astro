---
import { ViewTransitions } from 'astro:transitions';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Stargazer - Dark Sky Scotland</title>
    <ViewTransitions />

    <!-- MapLibre GL CSS -->
    <link href='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.css' rel='stylesheet' />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            line-height: 1.6;
            background: #000;
            color: #fff;
            overflow: hidden;
        }

        #app {
            height: 100vh;
            display: grid;
            grid-template-columns: 400px 1fr;
        }

        /* Sidebar */
        .sidebar {
            background: #111;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            padding: 20px;
            border-bottom: 1px solid #333;
        }

        .header h1 {
            font-size: 24px;
            font-weight: normal;
            margin-bottom: 8px;
        }

        .header .subtitle {
            color: #888;
            font-size: 12px;
        }

        /* Status indicators */
        .status-bar {
            display: flex;
            gap: 20px;
            padding: 15px 20px;
            background: #0a0a0a;
            border-bottom: 1px solid #333;
            font-size: 12px;
        }

        .status-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #444;
        }

        .status-indicator.active {
            background: #0f0;
            box-shadow: 0 0 8px #0f0;
        }

        /* Location list */
        .locations {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .location-card {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 4px;
            padding: 15px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .location-card:hover {
            background: #222;
            border-color: #0f0;
            transform: translateX(5px);
        }

        .location-card.selected {
            background: #0a2a0a;
            border-color: #0f0;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .location-name {
            font-weight: bold;
            color: #fff;
            font-size: 13px;
        }

        .rank-badge {
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 3px;
            font-weight: bold;
        }

        .rank-1 { background: #ffd700; color: #000; }
        .rank-2 { background: #c0c0c0; color: #000; }
        .rank-3 { background: #cd7f32; color: #000; }

        .score-display {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .score-value {
            font-size: 24px;
            font-weight: bold;
            min-width: 40px;
        }

        .score-bar {
            flex: 1;
            height: 6px;
            background: #333;
            border-radius: 3px;
            overflow: hidden;
        }

        .score-fill {
            height: 100%;
            transition: width 0.3s;
        }

        .location-details {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 6px;
            font-size: 11px;
            margin-bottom: 10px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 4px 8px;
            background: #0a0a0a;
            border-radius: 3px;
        }

        .detail-label {
            color: #666;
        }

        .detail-value {
            color: #aaa;
            font-weight: bold;
        }

        .next-clear {
            display: flex;
            justify-content: space-between;
            padding: 8px;
            background: #0a2a0a;
            border-radius: 3px;
            border: 1px solid #0f02;
            font-size: 11px;
        }

        .next-clear-label {
            color: #0a0;
        }

        .next-clear-value {
            color: #0f0;
            font-weight: bold;
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 200px;
            text-align: center;
            color: #666;
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 15px;
            opacity: 0.5;
        }

        .empty-title {
            font-size: 16px;
            color: #888;
            margin-bottom: 8px;
        }

        .empty-hint {
            font-size: 12px;
            color: #555;
        }

        /* Map container */
        #map {
            position: relative;
            width: 100%;
            height: 100%;
            background: #0a0a0a;
        }

        /* Map controls overlay */
        .map-controls {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.9);
            border: 1px solid #333;
            border-radius: 4px;
            padding: 10px;
            z-index: 1000;
        }

        .control-group {
            margin-bottom: 15px;
        }

        .control-group:last-child {
            margin-bottom: 0;
        }

        .control-label {
            font-size: 11px;
            color: #888;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .control-buttons {
            display: flex;
            gap: 5px;
        }

        .control-btn {
            padding: 5px 10px;
            background: #222;
            border: 1px solid #444;
            color: #fff;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }

        .control-btn:hover {
            background: #333;
            border-color: #0f0;
        }

        .control-btn.active {
            background: #0a2a0a;
            border-color: #0f0;
            color: #0f0;
        }

        /* Loading state */
        .loading {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            font-size: 14px;
            color: #888;
        }

        .loading::after {
            content: '';
            animation: dots 1.5s infinite;
        }

        @keyframes dots {
            0%, 20% { content: ''; }
            40% { content: '.'; }
            60% { content: '..'; }
            80%, 100% { content: '...'; }
        }

        /* Light pollution legend */
        .legend {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background: rgba(0, 0, 0, 0.9);
            border: 1px solid #333;
            border-radius: 4px;
            padding: 10px;
            font-size: 11px;
        }

        .legend-title {
            color: #888;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
        }

        .legend-color {
            width: 20px;
            height: 12px;
            border: 1px solid #444;
        }

        /* Mobile responsive */
        @media (max-width: 768px) {
            #app {
                grid-template-columns: 1fr;
                grid-template-rows: 1fr 1fr;
            }

            .sidebar {
                border-right: none;
                border-bottom: 1px solid #333;
            }

            .map-controls, .legend {
                transform: scale(0.9);
            }
        }

        /* Custom marker styles */
        .marker {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            border: 2px solid;
            cursor: pointer;
            transition: all 0.2s;
        }

        .marker:hover {
            transform: scale(1.5);
            filter: brightness(1.3);
            box-shadow: 0 0 15px currentColor;
        }

        .marker.selected {
            transform: scale(1.3);
            filter: brightness(1.5);
            box-shadow: 0 0 25px currentColor;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1.3); }
            50% { transform: scale(1.5); }
        }
    </style>
</head>
<body>
    <div id="app">
        <div class="sidebar">
            <div class="header">
                <h1>STARGAZER</h1>
                <div class="subtitle">Dark Sky Locations • Scotland</div>
            </div>

            <div class="status-bar">
                <div class="status-item">
                    <div class="status-indicator" id="data-status"></div>
                    <span>Data</span>
                </div>
                <div class="status-item">
                    <div class="status-indicator" id="weather-status"></div>
                    <span>Weather</span>
                </div>
                <div class="status-item">
                    <div class="status-indicator" id="forecast-status"></div>
                    <span>72h Forecast</span>
                </div>
            </div>

            <div class="locations" id="locations">
                <div class="loading">Loading locations</div>
            </div>
        </div>

        <div id="map">
            <div class="map-controls">
                <div class="control-group">
                    <div class="control-label">Time Range</div>
                    <div class="control-buttons">
                        <button class="control-btn active" data-range="tonight">Tonight</button>
                        <button class="control-btn" data-range="24h">24h</button>
                        <button class="control-btn" data-range="48h">48h</button>
                        <button class="control-btn" data-range="72h">72h</button>
                    </div>
                </div>

                <div class="control-group">
                    <div class="control-label">Min Score</div>
                    <div class="control-buttons">
                        <button class="control-btn active" data-score="60">60+</button>
                        <button class="control-btn" data-score="70">70+</button>
                        <button class="control-btn" data-score="80">80+</button>
                        <button class="control-btn" data-score="90">90+</button>
                    </div>
                </div>
            </div>

            <div class="legend">
                <div class="legend-title">Light Pollution</div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #000"></div>
                    <span>Pristine (Bortle 1)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #111"></div>
                    <span>Dark (Bortle 2)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #222"></div>
                    <span>Rural (Bortle 3)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-color" style="background: #444"></div>
                    <span>Suburban (Bortle 4+)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- MapLibre GL JS -->
    <script src='https://unpkg.com/maplibre-gl@4.0.0/dist/maplibre-gl.js'></script>

    <script>
        // API endpoint for Stargazer data
        const API_URL = 'https://api.jomcgi.dev/stargazer/best';

        let locations = [];
        const mockLocations = [
            {
                id: 'galloway-1',
                name: 'Galloway Forest Dark Sky Park',
                lat: 55.0833,
                lon: -4.5000,
                altitude_m: 320,
                lp_zone: '1a',
                score: 92,
                cloud_cover: 8,
                humidity: 65,
                wind_speed: 2.8,
                next_clear: 'Tonight 22:00',
                moon_phase: 'New Moon'
            },
            {
                id: 'cairngorms-1',
                name: 'Cairngorms National Park',
                lat: 57.0488,
                lon: -3.6106,
                altitude_m: 450,
                lp_zone: '1b',
                score: 87,
                cloud_cover: 15,
                humidity: 70,
                wind_speed: 3.5,
                next_clear: 'Tonight 23:00',
                moon_phase: 'New Moon'
            },
            {
                id: 'coll-1',
                name: 'Isle of Coll',
                lat: 56.6189,
                lon: -6.5572,
                altitude_m: 25,
                lp_zone: '0',
                score: 95,
                cloud_cover: 5,
                humidity: 60,
                wind_speed: 4.2,
                next_clear: 'Tonight 21:30',
                moon_phase: 'New Moon'
            },
            {
                id: 'skye-1',
                name: 'Quiraing, Isle of Skye',
                lat: 57.6433,
                lon: -6.2653,
                altitude_m: 280,
                lp_zone: '1a',
                score: 78,
                cloud_cover: 25,
                humidity: 75,
                wind_speed: 5.1,
                next_clear: 'Tomorrow 02:00',
                moon_phase: 'New Moon'
            },
            {
                id: 'sutherland-1',
                name: 'Northwest Sutherland',
                lat: 58.3500,
                lon: -4.7500,
                altitude_m: 150,
                lp_zone: '0',
                score: 88,
                cloud_cover: 12,
                humidity: 68,
                wind_speed: 3.2,
                next_clear: 'Tonight 22:30',
                moon_phase: 'New Moon'
            }
        ];

        let map;
        let markers = [];
        let selectedLocationId = null;

        // Initialize map
        function initMap() {
            map = new maplibregl.Map({
                container: 'map',
                style: {
                    version: 8,
                    sources: {
                        'osm': {
                            type: 'raster',
                            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
                            tileSize: 256,
                            attribution: '© OpenStreetMap contributors'
                        }
                    },
                    layers: [{
                        id: 'osm',
                        type: 'raster',
                        source: 'osm',
                        paint: {
                            'raster-brightness-min': 0.2,
                            'raster-brightness-max': 0.4,
                            'raster-contrast': 0.8
                        }
                    }],
                    glyphs: 'https://fonts.openmaptiles.org/{fontstack}/{range}.pbf'
                },
                center: [-4.5, 56.5], // Center of Scotland
                zoom: 6,
                pitch: 0,
                bearing: 0
            });

            // Add navigation controls
            map.addControl(new maplibregl.NavigationControl(), 'top-left');

            // Add markers for locations
            map.on('load', () => {
                addLocationMarkers();
                updateStatus();
            });
        }

        // Add markers to map
        function addLocationMarkers() {
            // Clear existing markers
            markers.forEach(m => m.marker.remove());
            markers = [];

            locations.forEach(location => {
                const el = document.createElement('div');
                el.className = 'marker';
                el.id = `marker-${location.id}`;

                // Color based on score
                const color = getScoreColor(location.score);
                const rgba = hexToRgba(color, 0.3);
                el.style.borderColor = color;
                el.style.background = rgba;

                const marker = new maplibregl.Marker(el)
                    .setLngLat([location.lon, location.lat])
                    .addTo(map);

                el.addEventListener('click', () => selectLocation(location.id));

                markers.push({ marker, location });
            });

            // Update location count
            updateLocationCount();
        }

        // Update location count display
        function updateLocationCount() {
            const subtitle = document.querySelector('.header .subtitle');
            if (subtitle) {
                subtitle.textContent = `Dark Sky Locations • ${locations.length} spots in Scotland`;
            }
        }

        // Get score color based on value
        function getScoreColor(score) {
            if (score >= 90) return '#00ff00';
            if (score >= 80) return '#88ff00';
            if (score >= 70) return '#ffff00';
            if (score >= 60) return '#ff8800';
            return '#ff0000';
        }

        // Convert hex color to rgba
        function hexToRgba(hex, alpha) {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
        }

        // Render location cards
        function renderLocations() {
            const container = document.getElementById('locations');
            container.innerHTML = '';

            if (locations.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">&#9734;</div>
                        <div class="empty-title">No locations match filters</div>
                        <div class="empty-hint">Try lowering the minimum score or expanding the time range</div>
                    </div>
                `;
                return;
            }

            // Sort by score descending
            const sorted = [...locations].sort((a, b) => b.score - a.score);

            sorted.forEach((location, index) => {
                const card = document.createElement('div');
                card.className = 'location-card';
                card.id = `card-${location.id}`;
                card.onclick = () => selectLocation(location.id);

                const scoreColor = getScoreColor(location.score);
                const rankBadge = index < 3 ? `<span class="rank-badge rank-${index + 1}">#${index + 1}</span>` : '';

                card.innerHTML = `
                    <div class="card-header">
                        <div class="location-name">${location.name}</div>
                        ${rankBadge}
                    </div>
                    <div class="score-display">
                        <span class="score-value" style="color: ${scoreColor}">${location.score}</span>
                        <div class="score-bar">
                            <div class="score-fill" style="width: ${location.score}%; background: ${scoreColor}"></div>
                        </div>
                    </div>
                    <div class="location-details">
                        <div class="detail-row">
                            <span class="detail-label">Zone</span>
                            <span class="detail-value">${location.lp_zone}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Cloud</span>
                            <span class="detail-value">${location.cloud_cover}%</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Wind</span>
                            <span class="detail-value">${location.wind_speed} m/s</span>
                        </div>
                        ${location.temperature !== null ? `
                        <div class="detail-row">
                            <span class="detail-label">Temp</span>
                            <span class="detail-value">${location.temperature}°C</span>
                        </div>
                        ` : ''}
                    </div>
                    ${location.next_clear ? `
                    <div class="next-clear">
                        <span class="next-clear-label">Best time:</span>
                        <span class="next-clear-value">${location.next_clear}</span>
                    </div>
                    ` : ''}
                `;

                container.appendChild(card);
            });
        }

        // Select location
        function selectLocation(locationId) {
            // Update selected state
            selectedLocationId = locationId;

            // Update cards
            document.querySelectorAll('.location-card').forEach(card => {
                card.classList.toggle('selected', card.id === `card-${locationId}`);
            });

            // Update markers
            document.querySelectorAll('.marker').forEach(marker => {
                marker.classList.toggle('selected', marker.id === `marker-${locationId}`);
            });

            // Pan map to location
            const location = locations.find(l => l.id === locationId);
            if (location) {
                map.flyTo({
                    center: [location.lon, location.lat],
                    zoom: 10,
                    duration: 1500
                });
            }
        }

        // Format time for display
        function formatTime(isoString) {
            if (!isoString) return null;
            const date = new Date(isoString);
            const now = new Date();
            const tomorrow = new Date(now);
            tomorrow.setDate(tomorrow.getDate() + 1);

            const timeStr = date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });

            if (date.toDateString() === now.toDateString()) {
                return `Tonight ${timeStr}`;
            } else if (date.toDateString() === tomorrow.toDateString()) {
                return `Tomorrow ${timeStr}`;
            } else {
                return date.toLocaleDateString('en-GB', { weekday: 'short', hour: '2-digit', minute: '2-digit' });
            }
        }

        // Format location ID into readable name
        function formatLocationName(id) {
            if (!id) return 'Unknown Location';
            // Convert "scotland_0010" to "Scotland #10"
            const parts = id.split('_');
            if (parts.length === 2) {
                const region = parts[0].charAt(0).toUpperCase() + parts[0].slice(1);
                const num = parseInt(parts[1], 10);
                return `${region} #${num}`;
            }
            return id;
        }

        // Fetch locations from API
        async function fetchLocations() {
            try {
                const response = await fetch(API_URL);
                if (response.ok) {
                    const apiData = await response.json();
                    // Transform API data to frontend format
                    locations = apiData
                        .map((loc, index) => {
                            // Validate coordinates - API returns {lat, lon} object
                            const lat = loc.coordinates?.lat;
                            const lon = loc.coordinates?.lon;

                            if (typeof lat !== 'number' || typeof lon !== 'number' ||
                                isNaN(lat) || isNaN(lon)) {
                                console.warn(`Skipping location ${loc.id}: invalid coordinates`, loc.coordinates);
                                return null;
                            }

                            const bestHour = loc.best_hours && loc.best_hours[0] || {};
                            return {
                                id: loc.id || `location-${index}`,
                                name: loc.name || formatLocationName(loc.id),
                                lat,
                                lon,
                                altitude_m: loc.altitude_m || 0,
                                lp_zone: loc.lp_zone || 'Unknown',
                                score: Math.round(loc.best_score || 0),
                                cloud_cover: Math.round(bestHour.cloud_area_fraction || 0),
                                humidity: Math.round(bestHour.relative_humidity || 0),
                                wind_speed: bestHour.wind_speed ? bestHour.wind_speed.toFixed(1) : '0',
                                temperature: bestHour.air_temperature ? Math.round(bestHour.air_temperature) : null,
                                next_clear: formatTime(bestHour.time)
                            };
                        })
                        .filter(loc => loc !== null); // Remove invalid locations

                    console.log(`Loaded ${locations.length} valid locations from API`);

                    if (locations.length === 0) {
                        console.warn('No valid locations from API, using demo data');
                        locations = mockLocations;
                    }
                } else {
                    console.warn('API unavailable, using demo data');
                    locations = mockLocations;
                }
            } catch (error) {
                console.error('Failed to fetch locations:', error);
                locations = mockLocations;
            }

            // Update UI
            renderLocations();
            if (map && map.loaded()) {
                addLocationMarkers();
            }
        }

        // Update status indicators
        function updateStatus() {
            document.getElementById('data-status').classList.add('active');
            setTimeout(() => {
                document.getElementById('weather-status').classList.add('active');
            }, 500);
            setTimeout(() => {
                document.getElementById('forecast-status').classList.add('active');
            }, 1000);
        }

        // Handle control buttons
        document.addEventListener('DOMContentLoaded', async () => {
            // Initialize map
            initMap();

            // Fetch and render locations
            await fetchLocations();

            // Time range controls
            document.querySelectorAll('[data-range]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('[data-range]').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    // TODO: Filter locations by time range
                });
            });

            // Score filter controls
            document.querySelectorAll('[data-score]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('[data-score]').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    const minScore = parseInt(e.target.dataset.score);
                    // TODO: Filter locations by minimum score
                });
            });
        });
    </script>
</body>
</html>