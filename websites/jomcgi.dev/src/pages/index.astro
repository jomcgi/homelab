---
import '../styling/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>jomcgi</title>
    <style>
        .container {
            max-width: 960px;
            margin: 0 auto;
            padding: 20px;
        }

        /* === IDENTITY MODULE === */
        /* Matches the rack pattern: black header + content */
        header {
            border: var(--border-heavy);
            margin-bottom: 0; /* Sections touch */
        }

        .identity-header {
            background: var(--fg);
            color: var(--bg);
            padding: var(--space-xs) var(--space-md);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .identity-content {
            padding: var(--space-md);
        }

        h1 {
            font-size: var(--text-xl);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: var(--space-sm);
        }

        .bio {
            margin-bottom: var(--space-xs);
            font-size: 13px;
        }

        .bio:last-of-type {
            margin-bottom: 0;
        }

        /* Contact grid - matches table aesthetic */
        .contact-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-top: var(--border-heavy);
            margin-top: var(--space-md);
            margin: var(--space-md) calc(-1 * var(--space-md)) calc(-1 * var(--space-md)) calc(-1 * var(--space-md)); /* Flush to edges */
        }

        .contact-grid a {
            padding: 10px;
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.05em;
            border-right: var(--border-heavy);
        }

        .contact-grid a:last-child {
            border-right: none;
        }

        .contact-grid a:hover {
            background: var(--fg);
            color: var(--bg);
            text-decoration: none;
        }

        /* === SECTIONS === */
        /* Rack units touch - no gaps */
        section {
            border: var(--border-heavy);
            border-top: none; /* Shares border with section above */
        }

        .section-content {
            padding: var(--space-md);
        }

        /* Project rows */
        .project {
            display: block;
            border-bottom: var(--border-heavy);
            padding: var(--space-sm) var(--space-md);
            margin: 0 calc(-1 * var(--space-md));
            transition: background 0.1s, color 0.1s;
        }

        .project:last-child {
            border-bottom: none;
            margin-bottom: calc(-1 * var(--space-md));
        }

        .project:first-child {
            margin-top: calc(-1 * var(--space-md));
        }

        /* Only linked projects are interactive */
        a.project {
            cursor: pointer;
        }

        a.project:hover {
            background: var(--fg);
            color: var(--bg);
            text-decoration: none;
        }

        .project-name {
            font-weight: bold;
            text-transform: uppercase;
            font-size: var(--text-sm);
            letter-spacing: 0.5px;
        }

        .project-desc {
            margin-top: 4px;
            font-size: 13px;
        }

        /* WIP projects - slightly dimmed */
        .project.wip {
            opacity: 0.7;
        }

        .project.wip .project-name::after {
            content: " [WIP]";
            font-size: 9px;
            opacity: 0.5;
            letter-spacing: 0.05em;
        }


        /* === HOMELAB RACK === */
        /* Single unit: header is label, grid is faceplate, no nested boxes */

        .homelab-section .section-content {
            padding: 0; /* Flush - grid IS the content */
        }

        /* Telemetry Grid - 4 columns, flush to section edge */
        /* 7 elements: STATUS+PODS(span-2), GITOPS, VER | NODES, CPU, MEM, GPU */
        #live-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-bottom: var(--border-heavy);
        }

        .stat-cell {
            padding: var(--space-sm);
            border-right: var(--border-heavy);
        }

        /* Row 1: STATUS spans 2 columns */
        .stat-cell.span-2 {
            grid-column: span 2;
        }

        /* Row divider: only row 1 (children 1-3) has border-bottom */
        .stat-cell:nth-child(-n+3) {
            border-bottom: var(--border-heavy);
        }

        /* Last column: no border-right (VER=3, GPU=7) */
        .stat-cell:nth-child(3),
        .stat-cell:nth-child(7) {
            border-right: none;
        }

        .stat-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            opacity: 0.6;
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: var(--text-sm);
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* Manifest Table - black sidebar is one continuous strip */
        .arch-grid {
            display: flex;
            flex-direction: column;
            gap: 0; /* Ensure no gaps between rows */
        }

        .arch-item {
            display: flex;
            margin: 0; /* Ensure no margin between rows */
        }

        .arch-key {
            width: 120px;
            flex-shrink: 0;
            background: var(--fg);
            color: var(--bg);
            padding: 10px var(--space-sm);
            font-size: var(--text-xs);
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            border-right: var(--border-heavy); /* Vertical divider on black cell */
            /* No border-bottom - creates infinite black bar */
        }

        .arch-val {
            flex: 1;
            padding: 10px var(--space-sm);
            font-size: var(--text-sm);
            display: flex;
            align-items: center;
            border-bottom: var(--border-heavy); /* Only white cells have horizontal dividers */
        }

        .arch-item:last-child .arch-val {
            border-bottom: none;
        }


        @media (max-width: 768px) {
            /* Telemetry: 2 columns on mobile */
            /* Layout: STATUS(full) | GITOPS, VER | NODES, CPU | MEM, GPU */
            #live-stats {
                grid-template-columns: repeat(2, 1fr);
            }
            .stat-cell.span-2 {
                grid-column: span 2; /* STATUS takes full width */
            }
            .stat-cell {
                border-right: var(--border-heavy);
                border-bottom: var(--border-heavy);
            }
            /* Right column: no border-right (children 1, 3, 5, 7) */
            .stat-cell:nth-child(1), /* STATUS spans full */
            .stat-cell:nth-child(3), /* VER */
            .stat-cell:nth-child(5), /* CPU */
            .stat-cell:nth-child(7) { /* GPU */
                border-right: none;
            }
            /* Last row: no border-bottom (MEM=6, GPU=7) */
            .stat-cell:nth-child(6),
            .stat-cell:nth-child(7) {
                border-bottom: none;
            }
            /* Manifest: narrower key column */
            .arch-key {
                width: 90px;
                font-size: 9px;
                padding: var(--space-xs) 10px;
            }
            .arch-val {
                padding: var(--space-xs) 10px;
                font-size: 11px;
            }
        }

        /* GitOps hover tooltip - shows sync time */
        .gitops-status {
            cursor: default;
            position: relative;
        }

        .gitops-status.has-sync-time {
            cursor: pointer;
        }

        .gitops-status.has-sync-time:hover {
            background: var(--fg);
            color: var(--bg);
        }

        /* === STATUS + POD MATRIX CELL === */
        /* Status on left, Pod Matrix (Scantron sheet) on right */
        .stat-cell.status-pod-cell {
            display: flex;
            padding: 0;
        }

        .status-pod-cell .status-side {
            padding: var(--space-sm);
            flex-shrink: 0;
        }

        .status-pod-cell .pod-matrix-side {
            flex: 1;
            min-width: 0; /* allow flex child to shrink below content size */
            padding: var(--space-xs) var(--space-sm);
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-left: var(--border-heavy);
        }

        .pod-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 3px; /* uniform grid spacing */
            cursor: crosshair;
        }

        /* Each pod is a small interactive square */
        /* :global() needed because these elements are created dynamically via JS */
        :global(.pod-dot) {
            width: 6px;
            height: 6px;
            background: var(--fg);
            flex-shrink: 0;
        }

        :global(.pod-dot:hover) {
            transform: scale(1.5);
        }

        :global(.pod-dot.pod-pending) {
            background: transparent;
            box-shadow: inset 0 0 0 1px var(--fg);
            animation: pod-pulse 1.5s ease-in-out infinite;
        }

        :global(.pod-dot.pod-failed) {
            background: #cc0000;
        }

        @keyframes pod-pulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }

        /* Inspector bar - shows pod details on hover */
        .pod-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.05em;
            margin-top: 6px;
            min-height: 14px;
        }

        /* :global() for dynamically created spans */
        :global(.pod-count-default) {
            opacity: 0.5;
        }

        :global(.pod-inspector) {
            color: var(--fg);
        }

        :global(.pod-inspector b) {
            font-weight: 700;
        }

        .pod-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.05em;
            margin-top: 6px;
            opacity: 0.6;
        }
    </style>
    <script is:inline>
        // Dark mode: check localStorage first, then system preference
        (function() {
            const stored = localStorage.getItem('darkMode');
            if (stored === 'true') {
                document.documentElement.classList.add('dark-pending');
            } else if (stored === 'false') {
                // Explicitly light mode
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.classList.add('dark-pending');
            }
        })();
    </script>
</head>
<body>
    <script is:inline>
        // Apply dark mode immediately to avoid flash
        if (document.documentElement.classList.contains('dark-pending')) {
            document.body.classList.add('dark');
            document.documentElement.classList.remove('dark-pending');
        }

        window.toggleDarkMode = function() {
            document.body.classList.toggle('dark');
            localStorage.setItem('darkMode', document.body.classList.contains('dark'));
        };
    </script>
    <div class="container">
        <header>
            <div class="identity-header">
                <span>Identity</span>
                <button class="toggle-btn" onclick="toggleDarkMode()">INVERT</button>
            </div>
            <div class="identity-content">
