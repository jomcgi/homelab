<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>jomci</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            line-height: 1.4;
            background: var(--bg);
            color: var(--fg);
            --bg: #fff;
            --fg: #000;
            transition: background 0.2s, color 0.2s;
        }
        
        body.dark {
            --bg: #000;
            --fg: #fff;
        }
        
        a {
            color: var(--fg);
            text-decoration: none;
        }
        
        .container {
            max-width: 960px;
            margin: 0 auto;
            padding: 20px;
        }
        
        /* === IDENTITY MODULE === */
        /* Matches the rack pattern: black header + content */
        header {
            border: 2px solid var(--fg);
            margin-bottom: 0; /* Sections touch */
        }

        .identity-header {
            background: var(--fg);
            color: var(--bg);
            padding: 8px 15px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 3px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .identity-content {
            padding: 15px;
        }

        h1 {
            font-size: 20px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 12px;
        }

        .bio {
            margin-bottom: 8px;
            font-size: 13px;
        }

        .bio:last-of-type {
            margin-bottom: 0;
        }

        /* Contact grid - matches table aesthetic */
        .contact-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-top: 2px solid var(--fg);
            margin-top: 15px;
            margin: 15px -15px -15px -15px; /* Flush to edges */
        }

        .contact-grid a {
            padding: 10px;
            text-align: center;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.05em;
            border-right: 2px solid var(--fg);
        }

        .contact-grid a:last-child {
            border-right: none;
        }

        .contact-grid a:hover {
            background: var(--fg);
            color: var(--bg);
        }
        
        /* === SECTIONS === */
        /* Rack units touch - no gaps */
        section {
            border: 2px solid var(--fg);
            border-top: none; /* Shares border with section above */
        }

        .section-header {
            background: var(--fg);
            color: var(--bg);
            padding: 8px 15px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 3px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-header a {
            color: var(--bg);
            font-size: 10px;
            opacity: 0.7;
        }

        .section-header a:hover {
            opacity: 1;
        }

        .section-content {
            padding: 15px;
        }

        /* Project rows */
        .project {
            display: block;
            border-bottom: 2px solid var(--fg);
            padding: 12px 15px;
            margin: 0 -15px;
            transition: background 0.1s, color 0.1s;
        }

        .project:last-child {
            border-bottom: none;
            margin-bottom: -15px;
        }

        .project:first-child {
            margin-top: -15px;
        }

        /* Only linked projects are interactive */
        a.project {
            cursor: pointer;
        }

        a.project:hover {
            background: var(--fg);
            color: var(--bg);
        }

        .project-name {
            font-weight: bold;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
        }

        .project-desc {
            margin-top: 4px;
            font-size: 13px;
        }

        /* WIP projects - slightly dimmed */
        .project.wip {
            opacity: 0.7;
        }

        .project.wip .project-name::after {
            content: " [WIP]";
            font-size: 9px;
            opacity: 0.5;
            letter-spacing: 0.05em;
        }
        

        /* === HOMELAB RACK === */
        /* Single unit: header is label, grid is faceplate, no nested boxes */

        .homelab-section .section-content {
            padding: 0; /* Flush - grid IS the content */
        }

        /* Telemetry Grid - 4 columns, flush to section edge */
        /* 7 elements: STATUS+PODS(span-2), GITOPS, VER | NODES, CPU, MEM, GPU */
        #live-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-bottom: 2px solid var(--fg);
        }

        .stat-cell {
            padding: 12px;
            border-right: 2px solid var(--fg);
        }

        /* Row 1: STATUS spans 2 columns */
        .stat-cell.span-2 {
            grid-column: span 2;
        }

        /* Row divider: only row 1 (children 1-3) has border-bottom */
        .stat-cell:nth-child(-n+3) {
            border-bottom: 2px solid var(--fg);
        }

        /* Last column: no border-right (VER=3, GPU=7) */
        .stat-cell:nth-child(3),
        .stat-cell:nth-child(7) {
            border-right: none;
        }

        .stat-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            opacity: 0.6;
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* Manifest Table - black sidebar is one continuous strip */
        .arch-grid {
            display: flex;
            flex-direction: column;
            gap: 0; /* Ensure no gaps between rows */
        }

        .arch-item {
            display: flex;
            margin: 0; /* Ensure no margin between rows */
        }

        .arch-key {
            width: 120px;
            flex-shrink: 0;
            background: var(--fg);
            color: var(--bg);
            padding: 10px 12px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            border-right: 2px solid var(--fg); /* Vertical divider on black cell */
            /* No border-bottom - creates infinite black bar */
        }

        .arch-val {
            flex: 1;
            padding: 10px 12px;
            font-size: 12px;
            display: flex;
            align-items: center;
            border-bottom: 2px solid var(--fg); /* Only white cells have horizontal dividers */
        }

        .arch-item:last-child .arch-val {
            border-bottom: none;
        }


        @media (max-width: 600px) {
            /* Telemetry: 2 columns on mobile */
            /* Layout: STATUS(full) | GITOPS, VER | NODES, CPU | MEM, GPU */
            #live-stats {
                grid-template-columns: repeat(2, 1fr);
            }
            .stat-cell.span-2 {
                grid-column: span 2; /* STATUS takes full width */
            }
            .stat-cell {
                border-right: 2px solid var(--fg);
                border-bottom: 2px solid var(--fg);
            }
            /* Right column: no border-right (children 1, 3, 5, 7) */
            .stat-cell:nth-child(1), /* STATUS spans full */
            .stat-cell:nth-child(3), /* VER */
            .stat-cell:nth-child(5), /* CPU */
            .stat-cell:nth-child(7) { /* GPU */
                border-right: none;
            }
            /* Last row: no border-bottom (MEM=6, GPU=7) */
            .stat-cell:nth-child(6),
            .stat-cell:nth-child(7) {
                border-bottom: none;
            }
            /* Manifest: narrower key column */
            .arch-key {
                width: 90px;
                font-size: 9px;
                padding: 8px 10px;
            }
            .arch-val {
                padding: 8px 10px;
                font-size: 11px;
            }
        }
        
        .toggle-btn {
            background: var(--bg);
            color: var(--fg);
            border: none;
            padding: 4px 8px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            cursor: pointer;
        }

        .toggle-btn:hover {
            opacity: 0.7;
        }

        /* Semantic Brutalist Colors */
        .st-ok { color: #00b300; }     /* Terminal Green */
        .st-warn { color: #ff9900; }   /* Amber */
        .st-err { color: #cc0000; }    /* Red */
        .st-dim { opacity: 0.3; }      /* Placeholder gray */

        .status-dot {
            display: inline-block;
            font-size: 14px;
            line-height: 1;
            vertical-align: middle;
        }

        /* === STATUS + POD MATRIX CELL === */
        /* Status on left, Pod Matrix (Scantron sheet) on right */
        .stat-cell.status-pod-cell {
            display: flex;
            padding: 0;
        }

        .status-pod-cell .status-side {
            padding: 12px;
            flex-shrink: 0;
        }

        .status-pod-cell .pod-matrix-side {
            flex: 1;
            padding: 8px 12px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-left: 2px solid var(--fg);
        }

        .pod-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 2px;
            font-family: monospace;
            font-size: 8px;
            line-height: 1;
        }

        /* Scantron Sheet: Black squares on white - rhymes with cp[■■■] */
        .pod-unit {
            width: 6px;
            height: 6px;
            background: var(--fg); /* Black square = Running */
        }

        .pod-unit.pending {
            background: transparent;
            border: 1px solid var(--fg); /* Hollow square = Pending */
            animation: pod-pulse 1.5s ease-in-out infinite;
        }

        .pod-unit.failed {
            background: #cc0000; /* Red = Failed */
        }

        .pod-unit.placeholder {
            background: transparent;
            border: 1px solid var(--fg);
            opacity: 0.3;
        }

        @keyframes pod-pulse {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 1; }
        }

        .pod-label {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.05em;
            margin-top: 6px;
            opacity: 0.6;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="identity-header">
                <span>Identity</span>
                <button class="toggle-btn" onclick="document.body.classList.toggle('dark')">INVERT</button>
            </div>
            <div class="identity-content">
                <h1>Joe McGinley</h1>
                <p class="bio">Mostly I build tools and infrastructure that other engineers don't have to think about.</p>
                <p class="bio">Based in Vancouver, originally from Scotland.</p>
                <p class="bio">Senior Platform Engineer @ <a href="https://semgrep.dev">Semgrep</a></p>
                <div class="contact-grid">
                    <a href="mailto:joe@jomcgi.dev">EMAIL</a>
                    <a href="https://www.linkedin.com/in/jomcgi/">LINKEDIN</a>
                    <a href="https://github.com/jomcgi">GITHUB</a>
                </div>
            </div>
        </header>

        <section>
            <div class="section-header">Side Quests</div>
            <div class="section-content">
                <a href="https://trips.jomcgi.dev" class="project">
                    <div class="project-name">trips.jomcgi.dev</div>
                    <div class="project-desc">Road trip tracker for our Yukon drive. On-the-road inference to detect wildlife from a car-mounted GoPro.</div>
                </a>
                <a href="/frank" class="project">
                    <div class="project-name">Frank x Vancouver</div>
                    <div class="project-desc">Trip website for my sister's visit.</div>
                </a>
                <a href="https://hikes.jomcgi.dev" class="project">
                    <div class="project-name">hikes.jomcgi.dev</div>
                    <div class="project-desc">Find hikes in Scotland with good weather right now. Forecast updates every 30 minutes.</div>
                </a>
            </div>
        </section>

        <section>
            <div class="section-header">Building</div>
            <div class="section-content">
                <div class="project wip">
                    <div class="project-name">Stargazer</div>
                    <div class="project-desc">Map of good stargazing spots. Filters for road access, low light pollution, clear forecasts.</div>
                </div>
                <div class="project wip">
                    <div class="project-name">Sextant</div>
                    <div class="project-desc">Generates typed Go for Kubernetes operators from declarative state machines.</div>
                </div>
                <div class="project wip">
                    <div class="project-name">Opencode WebUI</div>
                    <div class="project-desc">Self-hosted coding assistant. Sessions run as pods with access to multiple LLM backends.</div>
                </div>
                <div class="project wip">
                    <div class="project-name">Cloudflare Operator</div>
                    <div class="project-desc">Annotate a service with a domain → operator creates tunnels, DNS records, zero trust rules.</div>
                </div>
            </div>
        </section>

        <section class="homelab-section">
            <div class="section-header">
                <span>Homelab</span>
                <a href="https://github.com/jomcgi/homelab">github.com/jomcgi/homelab →</a>
            </div>
            <div class="section-content">
                <div id="live-stats">
                    <!-- Row 1: Status + Pod Matrix (span 2) | GitOps | Ver -->
                    <div class="stat-cell span-2 status-pod-cell">
                        <div class="status-side">
                            <div class="stat-label">Status</div>
                            <div class="stat-value">
                                <span id="sys-dot" class="status-dot st-dim">●</span>
                                <span id="sys-text">CONNECTING</span>
                            </div>
                        </div>
                        <div class="pod-matrix-side" id="pod-matrix">
                            <div class="pod-grid" id="pod-grid"></div>
                            <div class="pod-label"><span id="pod-count">--</span> pods</div>
                        </div>
                    </div>
                    <div class="stat-cell">
                        <div class="stat-label">GitOps</div>
                        <div class="stat-value" id="sys-gitops"><span class="st-dim">...</span></div>
                    </div>
                    <div class="stat-cell">
                        <div class="stat-label">Ver</div>
                        <div class="stat-value" id="sys-ver"><span class="st-dim">...</span></div>
                    </div>
                    <!-- Row 2: Nodes | CPU | Mem | GPU -->
                    <div class="stat-cell">
                        <div class="stat-label">Nodes</div>
                        <div class="stat-value" id="sys-nodes"><span class="st-dim">...</span></div>
                    </div>
                    <div class="stat-cell">
                        <div class="stat-label">CPU</div>
                        <div class="stat-value" id="sys-cpu"><span class="st-dim">...</span></div>
                    </div>
                    <div class="stat-cell">
                        <div class="stat-label">Mem</div>
                        <div class="stat-value" id="sys-mem"><span class="st-dim">...</span></div>
                    </div>
                    <div class="stat-cell">
                        <div class="stat-label">GPU</div>
                        <div class="stat-value" id="sys-gpu"><span class="st-dim">...</span></div>
                    </div>
                </div>

                <div class="arch-grid">
                    <div class="arch-item">
                        <div class="arch-key">Monorepo</div>
                        <div class="arch-val">Don't want to spread context or build processes across repos</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Bazel</div>
                        <div class="arch-val">Multi-language builds, multiplatform images with apko. Write a rule once, reuse it everywhere</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">GitOps</div>
                        <div class="arch-val">ArgoCD — mirrors what I maintain at work, scales to multiple clusters</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Ingress</div>
                        <div class="arch-val">Cloudflare Tunnels via my operator. No open ports on my home network</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Policy</div>
                        <div class="arch-val">Kyverno to catch mistakes — no peer reviews here</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Observability</div>
                        <div class="arch-val">OTel auto-instrumentation where suitable, self-hosted SigNoz</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Storage</div>
                        <div class="arch-val">Longhorn for PVs, avoiding state where possible. Critical data backed up offsite</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Mesh</div>
                        <div class="arch-val">Linkerd for service-to-service mTLS and telemetry</div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script>
        // Render the Pod Matrix - LED array visualization
        function renderPodMatrix(els, podsData) {
            // Clear existing
            els.podGrid.innerHTML = '';

            // If no pod data, show placeholder squares
            if (!podsData || (!podsData.statuses && podsData.running === undefined)) {
                // Placeholder: show dim hollow squares
                for (let i = 0; i < 30; i++) {
                    const dot = document.createElement('div');
                    dot.className = 'pod-unit placeholder';
                    els.podGrid.appendChild(dot);
                }
                els.podCount.innerText = '--';
                return;
            }

            // Handle array of statuses: ["Running", "Running", "Pending", ...]
            if (podsData.statuses && Array.isArray(podsData.statuses)) {
                podsData.statuses.forEach(status => {
                    const dot = document.createElement('div');
                    const normalizedStatus = status.toLowerCase();
                    if (normalizedStatus === 'running' || normalizedStatus === 'succeeded') {
                        dot.className = 'pod-unit'; // Solid black square
                    } else if (normalizedStatus === 'pending' || normalizedStatus === 'containercreating') {
                        dot.className = 'pod-unit pending'; // Hollow square
                    } else {
                        dot.className = 'pod-unit failed'; // Red square
                    }
                    els.podGrid.appendChild(dot);
                });
                els.podCount.innerText = podsData.statuses.length;
                return;
            }

            // Handle counts: { running: 38, pending: 2, failed: 1, succeeded: 5 }
            const running = podsData.running || 0;
            const succeeded = podsData.succeeded || 0;
            const pending = podsData.pending || 0;
            const failed = podsData.failed || 0;
            const healthy = running + succeeded;
            const total = healthy + pending + failed;

            // Healthy pods (running + succeeded) - solid black squares ■
            for (let i = 0; i < healthy; i++) {
                const dot = document.createElement('div');
                dot.className = 'pod-unit';
                els.podGrid.appendChild(dot);
            }
            // Pending pods - hollow squares □
            for (let i = 0; i < pending; i++) {
                const dot = document.createElement('div');
                dot.className = 'pod-unit pending';
                els.podGrid.appendChild(dot);
            }
            // Failed pods - red squares
            for (let i = 0; i < failed; i++) {
                const dot = document.createElement('div');
                dot.className = 'pod-unit failed';
                els.podGrid.appendChild(dot);
            }

            els.podCount.innerText = total;
        }

        async function fetchStats() {
            const els = {
                dot: document.getElementById('sys-dot'),
                text: document.getElementById('sys-text'),
                nodes: document.getElementById('sys-nodes'),
                cpu: document.getElementById('sys-cpu'),
                mem: document.getElementById('sys-mem'),
                gpu: document.getElementById('sys-gpu'),
                gitops: document.getElementById('sys-gitops'),
                ver: document.getElementById('sys-ver'),
                podGrid: document.getElementById('pod-grid'),
                podCount: document.getElementById('pod-count')
            };

            try {
                const res = await fetch('https://api.jomcgi.dev/cluster-info?t=' + Date.now());
                if (!res.ok) throw new Error('Fetch failed');

                const data = await res.json();
                const now = new Date();
                const lastUpdate = new Date(data.updated_at);
                const diffMs = now - lastUpdate;

                // Deadman Switch: If data > 1 hour old, show OFFLINE
                if (diffMs > 3600000) {
                    setOfflineState(els, 'OFFLINE');
                    return;
                }

                // Stale Data Check: If data > 60s old, warn but show data
                if (diffMs > 60000) {
                    els.dot.className = 'status-dot st-warn';
                    els.text.innerText = 'STALE';
                } else {
                    els.dot.className = 'status-dot st-ok';
                    els.text.innerText = 'ONLINE';
                }

                // Render Nodes - categorized: cp[■■■] gpu[■]
                let html = '';

                // Control plane nodes
                if (data.nodes.cp) {
                    html += 'cp[';
                    for (let i = 0; i < data.nodes.cp.total; i++) {
                        const colorClass = (i < data.nodes.cp.ready) ? 'st-ok' : 'st-err';
                        html += `<span class="${colorClass}" style="margin:0 1px">■</span>`;
                    }
                    html += '] ';
                }

                // GPU nodes
                if (data.nodes.gpu && data.nodes.gpu.total > 0) {
                    html += 'gpu[';
                    for (let i = 0; i < data.nodes.gpu.total; i++) {
                        const colorClass = (i < data.nodes.gpu.ready) ? 'st-ok' : 'st-err';
                        html += `<span class="${colorClass}" style="margin:0 1px">■</span>`;
                    }
                    html += ']';
                }

                // Fallback for old API format
                if (!data.nodes.cp && data.nodes.total !== undefined) {
                    for (let i = 0; i < data.nodes.total; i++) {
                        const colorClass = (i < data.nodes.ready) ? 'st-ok' : 'st-err';
                        html += `<span class="${colorClass}" style="margin-right:2px">■</span>`;
                    }
                }

                els.nodes.innerHTML = html;

                // Render CPU
                let cpuClass = '';
                if (data.cpu > 80) cpuClass = 'st-err';
                else if (data.cpu > 50) cpuClass = 'st-warn';
                els.cpu.innerHTML = `<span class="${cpuClass}">${data.cpu}%</span>`;

                // Render Memory
                const memPercent = (data.mem.used / data.mem.total) * 100;
                let memClass = '';
                if (memPercent > 90) memClass = 'st-err';
                else if (memPercent > 80) memClass = 'st-warn';
                els.mem.innerHTML = `<span class="${memClass}">${data.mem.used}/${data.mem.total}GB</span>`;

                // Render GPU
                if (data.gpu_util !== undefined && data.gpu_util !== null) {
                    let gpuClass = '';
                    if (data.gpu_util > 90) gpuClass = 'st-err';
                    else if (data.gpu_util > 70) gpuClass = 'st-warn';
                    const vramStr = data.vram ? ` (${data.vram.used}/${data.vram.total}GB)` : '';
                    els.gpu.innerHTML = `<span class="${gpuClass}">${data.gpu_util}%${vramStr}</span>`;
                } else {
                    els.gpu.innerHTML = '<span class="st-dim">--</span>';
                }

                // Render Pod Matrix
                renderPodMatrix(els, data.pods);

                // Render GitOps status
                if (data.gitops) {
                    const status = data.gitops.status || 'Unknown';
                    els.gitops.innerText = `[${status}]`;
                    els.gitops.className = '';
                    if (status === 'Synced') els.gitops.className = 'st-ok';
                    else if (status === 'OutOfSync') els.gitops.className = 'st-warn';
                    else if (status === 'Unknown') els.gitops.className = 'st-err';

                    // Render version (git revision)
                    const rev = data.gitops.revision || '';
                    els.ver.innerText = rev ? `[${rev}]` : '[--]';
                }

            } catch (e) {
                setOfflineState(els, 'UNREACHABLE');
            }
        }

        function setOfflineState(els, reason) {
            els.dot.className = 'status-dot st-err';
            els.text.innerText = reason;
            els.nodes.innerHTML = '<span class="st-dim">--</span>';
            els.cpu.innerHTML = '<span class="st-dim">--</span>';
            els.mem.innerHTML = '<span class="st-dim">--</span>';
            els.gpu.innerHTML = '<span class="st-dim">--</span>';
            els.gitops.innerHTML = '<span class="st-dim">[--]</span>';
            els.ver.innerHTML = '<span class="st-dim">[--]</span>';
            // Reset pod matrix to placeholder state
            renderPodMatrix(els, null);
        }

        fetchStats();
        setInterval(fetchStats, 5000);
    </script>
</body>
</html>