<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Joe McGinley</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            line-height: 1.4;
            background: var(--bg);
            color: var(--fg);
            --bg: #fff;
            --fg: #000;
            transition: background 0.2s, color 0.2s;
        }
        
        body.dark {
            --bg: #000;
            --fg: #fff;
        }
        
        a {
            color: var(--fg);
            text-decoration: none;
        }
        
        .container {
            max-width: 960px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            border: 2px solid var(--fg);
            padding: 20px;
            margin-bottom: 20px;
        }
        
        h1 {
            font-size: 24px;
            font-weight: normal;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .bio {
            margin-bottom: 8px;
        }
        
        .bio:last-of-type {
            margin-bottom: 15px;
        }
        
        .links {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            font-size: 12px;
        }
        
        .links a:hover {
            background: var(--fg);
            color: var(--bg);
        }
        
        section {
            border: 2px solid var(--fg);
            margin-bottom: 20px;
        }
        
        .section-header {
            background: var(--fg);
            color: var(--bg);
            padding: 8px 15px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 3px;
        }
        
        .section-content {
            padding: 15px;
        }
        
        .project {
            border-bottom: 1px solid var(--fg);
            padding: 12px 0;
        }
        
        .project:last-child {
            border-bottom: none;
        }
        
        .project-name {
            font-weight: bold;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
        }
        
        .project-name a:hover {
            background: var(--fg);
            color: var(--bg);
        }
        
        .project-desc {
            margin-top: 4px;
            font-size: 13px;
        }
        
        .arch-grid {
            display: grid;
            grid-template-columns: 120px 1fr;
            gap: 2px;
        }
        
        .arch-item {
            display: contents;
        }
        
        .arch-key {
            background: var(--fg);
            color: var(--bg);
            padding: 6px 10px;
            font-size: 11px;
            text-transform: uppercase;
        }
        
        .arch-val {
            border: 1px solid var(--fg);
            padding: 6px 10px;
            font-size: 12px;
        }
        
        footer {
            border: 2px solid var(--fg);
            padding: 15px;
            font-size: 12px;
        }
        
        footer a:hover {
            background: var(--fg);
            color: var(--bg);
        }
        
        .cluster-info {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
        }

        #live-stats {
            margin-bottom: 20px;
            border-top: 1px solid var(--fg);
            border-bottom: 1px solid var(--fg);
        }

        .status-strip {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 15px;
            padding: 10px 0;
            font-size: 12px;
        }

        .status-strip + .status-strip {
            border-top: 1px dashed var(--fg);
        }

        .stat-group {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .stat-label {
            font-weight: bold;
            opacity: 0.8;
        }

        .stat-sep {
            opacity: 0.3;
        }

        @media (max-width: 600px) {
            .arch-grid {
                grid-template-columns: 100px 1fr;
            }
            .arch-key {
                font-size: 10px;
            }
            .stat-sep {
                display: none;
            }
            .status-strip {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
        }
        
        .toggle-btn {
            background: var(--fg);
            color: var(--bg);
            border: none;
            padding: 6px 12px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }
        
        .toggle-btn:hover {
            opacity: 0.8;
        }
        
        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }

        /* Semantic Brutalist Colors */
        .st-ok { color: #00b300; }     /* Terminal Green */
        .st-warn { color: #ff9900; }   /* Amber */
        .st-err { color: #cc0000; }    /* Red */
        .st-dim { opacity: 0.3; }      /* Placeholder gray */

        .status-dot {
            display: inline-block;
            font-size: 14px;
            line-height: 1;
            vertical-align: middle;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="header-row">
                <h1>Joe McGinley</h1>
                <button class="toggle-btn" onclick="document.body.classList.toggle('dark')">[INVERT]</button>
            </div>
            <p class="bio">Mostly I build tools and infrastructure that other engineers don't have to think about.</p>
            <p class="bio">Based in Vancouver, originally from Scotland.</p>
            <p class="bio">Senior Platform Engineer @ Semgrep.</p>
            <div class="links">
                <a href="mailto:joe@jomcgi.dev">[EMAIL]</a>
                <a href="https://www.linkedin.com/in/jomcgi/">[LINKEDIN]</a>
                <a href="https://github.com/jomcgi">[GITHUB]</a>
            </div>
        </header>

        <section>
            <div class="section-header">Side Quests</div>
            <div class="section-content">
                <div class="project">
                    <div class="project-name"><a href="https://trips.jomcgi.dev">trips.jomcgi.dev</a></div>
                    <div class="project-desc">Road trip tracker for our Yukon drive. On-the-road inference to detect wildlife from a car-mounted GoPro.</div>
                </div>
                <div class="project">
                    <div class="project-name"><a href="/frank">Frank x Vancouver</a></div>
                    <div class="project-desc">Trip website for my sister's visit.</div>
                </div>
                <div class="project">
                    <div class="project-name"><a href="https://hikes.jomcgi.dev">hikes.jomcgi.dev</a></div>
                    <div class="project-desc">Find hikes in Scotland with good weather right now. Forecast updates every 30 minutes.</div>
                </div>
            </div>
        </section>

        <section>
            <div class="section-header">Building</div>
            <div class="section-content">
                <div class="project">
                    <div class="project-name">Stargazer</div>
                    <div class="project-desc">Map of good stargazing spots. Filters for road access, low light pollution, clear forecasts.</div>
                </div>
                <div class="project">
                    <div class="project-name">Sextant</div>
                    <div class="project-desc">Generates typed Go for Kubernetes operators from declarative state machines.</div>
                </div>
                <div class="project">
                    <div class="project-name">Opencode WebUI</div>
                    <div class="project-desc">Self-hosted coding assistant. Sessions run as pods with access to multiple LLM backends.</div>
                </div>
                <div class="project">
                    <div class="project-name">Cloudflare Operator</div>
                    <div class="project-desc">Annotate a service with a domain → operator creates tunnels, DNS records, zero trust rules.</div>
                </div>
            </div>
        </section>

        <section>
            <div class="section-header">Homelab</div>
            <div class="section-content">
                <div class="cluster-info">4-node Kubernetes cluster running in my office</div>

                <div id="live-stats">
                    <div class="status-strip">
                        <div class="stat-group">
                            <span class="stat-label">STATUS:</span>
                            <span id="sys-dot" class="status-dot st-dim">●</span>
                            <span id="sys-text">CONNECTING</span>
                        </div>
                        <span class="stat-sep">|</span>
                        <div class="stat-group">
                            <span class="stat-label">GITOPS:</span>
                            <span id="sys-gitops"><span class="st-dim">...</span></span>
                        </div>
                        <span class="stat-sep">|</span>
                        <div class="stat-group">
                            <span class="stat-label">VER:</span>
                            <span id="sys-ver"><span class="st-dim">...</span></span>
                        </div>
                    </div>
                    <div class="status-strip">
                        <div class="stat-group">
                            <span class="stat-label">NODES:</span>
                            <span id="sys-nodes"><span class="st-dim">...</span></span>
                        </div>
                        <span class="stat-sep">|</span>
                        <div class="stat-group">
                            <span class="stat-label">CPU:</span>
                            <span id="sys-cpu"><span class="st-dim">...</span></span>
                        </div>
                        <span class="stat-sep">|</span>
                        <div class="stat-group">
                            <span class="stat-label">MEM:</span>
                            <span id="sys-mem"><span class="st-dim">...</span></span>
                        </div>
                        <span class="stat-sep">|</span>
                        <div class="stat-group">
                            <span class="stat-label">GPU:</span>
                            <span id="sys-gpu"><span class="st-dim">...</span></span>
                        </div>
                        <span class="stat-sep">|</span>
                        <div class="stat-group">
                            <span class="stat-label">VRAM:</span>
                            <span id="sys-vram"><span class="st-dim">...</span></span>
                        </div>
                    </div>
                </div>

                <div class="arch-grid">
                    <div class="arch-item">
                        <div class="arch-key">Monorepo</div>
                        <div class="arch-val">Don't want to spread context or build processes across repos</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Bazel</div>
                        <div class="arch-val">Multi-language builds, multiplatform images with apko. Write a rule once, benefit for years</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">GitOps</div>
                        <div class="arch-val">ArgoCD — mirrors what I maintain at work, scales to multiple clusters</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Ingress</div>
                        <div class="arch-val">Cloudflare Tunnels in-cluster via my operator, zero trust SSO</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Policy</div>
                        <div class="arch-val">Kyverno to catch mistakes — no peer reviews here</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Observability</div>
                        <div class="arch-val">OTel auto-instrumentation where suitable, self-hosted SigNoz</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Storage</div>
                        <div class="arch-val">Longhorn for PVs, avoiding state where possible. Critical data backed up offsite</div>
                    </div>
                    <div class="arch-item">
                        <div class="arch-key">Mesh</div>
                        <div class="arch-val">Linkerd for service-to-service mTLS and telemetry</div>
                    </div>
                </div>
            </div>
        </section>

        <footer>
            <a href="https://github.com/jomcgi/homelab">github.com/jomcgi/homelab</a>
        </footer>
    </div>

    <script>
        async function fetchStats() {
            const els = {
                dot: document.getElementById('sys-dot'),
                text: document.getElementById('sys-text'),
                nodes: document.getElementById('sys-nodes'),
                cpu: document.getElementById('sys-cpu'),
                mem: document.getElementById('sys-mem'),
                gpu: document.getElementById('sys-gpu'),
                vram: document.getElementById('sys-vram'),
                gitops: document.getElementById('sys-gitops'),
                ver: document.getElementById('sys-ver')
            };

            try {
                const res = await fetch('https://api.jomcgi.dev/cluster-info?t=' + Date.now());
                if (!res.ok) throw new Error('Fetch failed');

                const data = await res.json();
                const now = new Date();
                const lastUpdate = new Date(data.updated_at);
                const diffMs = now - lastUpdate;

                // Deadman Switch: If data > 1 hour old, show OFFLINE
                if (diffMs > 3600000) {
                    setOfflineState(els, 'OFFLINE');
                    return;
                }

                // Stale Data Check: If data > 60s old, warn but show data
                if (diffMs > 60000) {
                    els.dot.className = 'status-dot st-warn';
                    els.text.innerText = 'STALE';
                } else {
                    els.dot.className = 'status-dot st-ok';
                    els.text.innerText = 'ONLINE';
                }

                // Render Nodes - categorized: cp[■■■] gpu[■]
                let html = '';

                // Control plane nodes
                if (data.nodes.cp) {
                    html += 'cp[';
                    for (let i = 0; i < data.nodes.cp.total; i++) {
                        const colorClass = (i < data.nodes.cp.ready) ? 'st-ok' : 'st-err';
                        html += `<span class="${colorClass}" style="margin:0 1px">■</span>`;
                    }
                    html += '] ';
                }

                // GPU nodes
                if (data.nodes.gpu && data.nodes.gpu.total > 0) {
                    html += 'gpu[';
                    for (let i = 0; i < data.nodes.gpu.total; i++) {
                        const colorClass = (i < data.nodes.gpu.ready) ? 'st-ok' : 'st-err';
                        html += `<span class="${colorClass}" style="margin:0 1px">■</span>`;
                    }
                    html += ']';
                }

                // Fallback for old API format
                if (!data.nodes.cp && data.nodes.total !== undefined) {
                    for (let i = 0; i < data.nodes.total; i++) {
                        const colorClass = (i < data.nodes.ready) ? 'st-ok' : 'st-err';
                        html += `<span class="${colorClass}" style="margin-right:2px">■</span>`;
                    }
                }

                els.nodes.innerHTML = html;

                // Render CPU
                els.cpu.innerText = `${data.cpu}%`;
                els.cpu.className = '';
                if (data.cpu > 80) els.cpu.className = 'st-err';
                else if (data.cpu > 50) els.cpu.className = 'st-warn';

                // Render Memory
                const memPercent = (data.mem.used / data.mem.total) * 100;
                els.mem.innerText = `${data.mem.used}GB / ${data.mem.total}GB`;
                els.mem.className = '';
                if (memPercent > 90) els.mem.className = 'st-err';
                else if (memPercent > 80) els.mem.className = 'st-warn';

                // Render GPU utilization
                if (data.gpu_util !== undefined && data.gpu_util !== null) {
                    els.gpu.innerText = `${data.gpu_util}%`;
                    els.gpu.className = '';
                    if (data.gpu_util > 90) els.gpu.className = 'st-err';
                    else if (data.gpu_util > 70) els.gpu.className = 'st-warn';
                } else {
                    els.gpu.innerHTML = '<span class="st-dim">--</span>';
                }

                // Render VRAM
                if (data.vram) {
                    els.vram.innerText = `${data.vram.used}/${data.vram.total}GB`;
                    const vramPercent = (data.vram.used / data.vram.total) * 100;
                    els.vram.className = '';
                    if (vramPercent > 95) els.vram.className = 'st-err';
                    else if (vramPercent > 85) els.vram.className = 'st-warn';
                } else {
                    els.vram.innerHTML = '<span class="st-dim">--</span>';
                }

                // Render GitOps status
                if (data.gitops) {
                    const status = data.gitops.status || 'Unknown';
                    els.gitops.innerText = `[${status}]`;
                    els.gitops.className = '';
                    if (status === 'Synced') els.gitops.className = 'st-ok';
                    else if (status === 'OutOfSync') els.gitops.className = 'st-warn';
                    else if (status === 'Unknown') els.gitops.className = 'st-err';

                    // Render version (git revision)
                    const rev = data.gitops.revision || '';
                    els.ver.innerText = rev ? `[${rev}]` : '[--]';
                }

            } catch (e) {
                setOfflineState(els, 'UNREACHABLE');
            }
        }

        function setOfflineState(els, reason) {
            els.dot.className = 'status-dot st-err';
            els.text.innerText = reason;
            els.nodes.innerHTML = '<span class="st-dim">--</span>';
            els.cpu.innerHTML = '<span class="st-dim">--</span>';
            els.mem.innerHTML = '<span class="st-dim">--</span>';
            els.gpu.innerHTML = '<span class="st-dim">--</span>';
            els.vram.innerHTML = '<span class="st-dim">--</span>';
            els.gitops.innerHTML = '<span class="st-dim">[--]</span>';
            els.ver.innerHTML = '<span class="st-dim">[--]</span>';
        }

        fetchStats();
        setInterval(fetchStats, 5000);
    </script>
</body>
</html>