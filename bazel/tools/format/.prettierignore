# Helm templates contain Go template syntax that Prettier doesn't understand
charts/*/templates/
projects/**/templates/

# CRD manifests are auto-generated by controller-gen and should not be reformatted
charts/*/crds/
projects/**/crds/

# Minified/bundled assets should not be reformatted
**/dist/

# Git worktrees have their own formatting
.claude/worktrees/
