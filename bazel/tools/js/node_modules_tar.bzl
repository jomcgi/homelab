"""node_modules_tar - package js_library targets into apko-compatible tars"""

def node_modules_tar(
        name,
        deps,
        package_dir = "/usr/local/lib/node_modules",
        visibility = None):
    """Package js_library node_modules into a tar for apko images.

    This macro handles the complexity of packaging npm dependencies from rules_js
    into a proper node_modules structure with .bin symlinks.

    Args:
        name: Name of the tar target
        deps: List of js_library targets (e.g., ["//:claude_code"])
        package_dir: Where to install node_modules (default: /usr/local/lib/node_modules)
        visibility: Visibility of the generated tar

    Example:
        load("//bazel/tools/js:node_modules_tar.bzl", "node_modules_tar")

        node_modules_tar(
            name = "node_modules_tar",
            deps = ["//:claude_code"],
        )

        apko_image(
            name = "my_image",
            tars = [":node_modules_tar"],
        )
    """
    native.genrule(
        name = name,
        srcs = deps,
        outs = [name + ".tar"],
        cmd = """
            set -euo pipefail

            # Create directory structure
            mkdir -p tmp{package_dir}/.bin

            echo "Processing sources..."
            # Process each package
            for src in $(SRCS); do
                echo "Source: $$src"
                # Skip if not a directory/file we can process
                if [[ ! -e $$src ]]; then
                    echo "  Does not exist, skipping"
                    continue
                fi

                # Find package.json files (follow symlinks)
                find -L $$src -name package.json -type f | while read pkg; do
                    echo "  Found package.json: $$pkg"
                    PKG_DIR=$$(dirname $$pkg)

                    # Extract package name and bin info
                    PACKAGE_NAME=$$(cat $$pkg | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | cut -d'"' -f4 || true)

                    if [[ -n "$$PACKAGE_NAME" ]]; then
                        # Determine target directory based on scope
                        if [[ $$PACKAGE_NAME == @* ]]; then
                            # Scoped package
                            SCOPE=$$(echo $$PACKAGE_NAME | cut -d'/' -f1)
                            PKG_NAME=$$(echo $$PACKAGE_NAME | cut -d'/' -f2)
                            TARGET_DIR="tmp{package_dir}/$$SCOPE/$$PKG_NAME"
                        else
                            # Non-scoped package
                            TARGET_DIR="tmp{package_dir}/$$PACKAGE_NAME"
                        fi

                        # Copy package (follow symlinks)
                        mkdir -p "$$(dirname $$TARGET_DIR)"
                        cp -rL $$PKG_DIR $$TARGET_DIR

                        # Create .bin symlinks if package has bin entries
                        cat $$pkg | grep -A 100 '"bin"' | grep -E '"[^"]+": "[^"]+"' | while read -r line; do
                            BIN_NAME=$$(echo $$line | grep -o '"[^"]*"' | head -1 | tr -d '"' || true)
                            BIN_PATH=$$(echo $$line | grep -o '"[^"]*"' | tail -1 | tr -d '"' || true)

                            if [[ -n "$$BIN_NAME" ]] && [[ -n "$$BIN_PATH" ]] && [[ "$$BIN_NAME" != "bin" ]]; then
                                # Create relative symlink from .bin to package
                                REL_PATH=$$(realpath --relative-to="tmp{package_dir}/.bin" "$$TARGET_DIR/$$BIN_PATH" || echo "../$$PACKAGE_NAME/$$BIN_PATH")
                                ln -sf "$$REL_PATH" "tmp{package_dir}/.bin/$$BIN_NAME" || true
                            fi
                        done || true
                    fi
                done
            done

            # Create tar
            tar -C tmp -czf $@ .
        """.format(package_dir = package_dir),
        visibility = visibility,
    )
