semgrep_pro = use_extension("//bazel/semgrep/third_party/semgrep_pro:extensions.bzl", "semgrep_pro")
use_repo(
    semgrep_pro,
    "semgrep_pro_engine_amd64",
    "semgrep_pro_engine_arm64",
    "semgrep_pro_engine_osx_arm64",
    "semgrep_pro_engine_osx_x86_64",
    "semgrep_pro_rules_golang",
    "semgrep_pro_rules_javascript",
    "semgrep_pro_rules_kubernetes",
    "semgrep_pro_rules_python",
    "semgrep_sca_rules_golang",
    "semgrep_sca_rules_javascript",
    "semgrep_sca_rules_python",
)

