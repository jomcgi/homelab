semgrep = use_extension("//bazel/semgrep/third_party/semgrep:extensions.bzl", "semgrep")
use_repo(
    semgrep,
    "semgrep_engine_amd64",
    "semgrep_engine_arm64",
    "semgrep_engine_osx_arm64",
    "semgrep_engine_osx_x86_64",
)

# Configure apko for container images
apko = use_extension("@rules_apko//apko:extensions.bzl", "apko")
apko.translate_lock(
