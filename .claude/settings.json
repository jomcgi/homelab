{
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cd /tmp/claude-worktrees:*)",
      "Bash(cd /private/tmp/claude-worktrees:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C:*)",
      "Bash(gh:*)",
      "Bash(bazelisk:*)",
      "Bash(format:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(helm dependency:*)",
      "Bash(helm show:*)",
      "Bash(helm uninstall:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(go:*)",
      "Bash(operator-sdk:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(lstr:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(crane:*)",
      "Bash(wc:*)",
      "Bash(column:*)",
      "WebFetch(domain:*)",
      "Bash(bb:*)"
    ],
    "additionalDirectories": ["/tmp/claude-worktrees"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bazel/tools/git/check-stale-pr.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/prefer-bb-remote.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bazel/tools/hooks/pretooluse-write-edit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-unnecessary-chart-bump.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "impeccable@impeccable": true
  }
}
