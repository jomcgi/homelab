{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "tools/git/check-stale-pr.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C:*)",
      "Bash(gh:*)",
      "Bash(bazelisk:*)",
      "Bash(format:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(helm dependency:*)",
      "Bash(helm show:*)",
      "Bash(helm uninstall:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(argocd app list:*)",
      "Bash(argocd app get:*)",
      "Bash(argocd app diff:*)",
      "Bash(argocd app history:*)",
      "Bash(go:*)",
      "Bash(operator-sdk:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(lstr:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(crane:*)",
      "Bash(wc:*)",
      "Bash(column:*)",
      "WebFetch(domain:*)"
    ],
    "additionalDirectories": ["/tmp/claude-worktrees"]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true
  }
}
