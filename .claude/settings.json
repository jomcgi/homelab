{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚡ TOKEN CHECK: Reading 10+ files or generating code? Use /opencode (FREE local Qwen). See .claude/skills/opencode/SKILL.md'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go mod:*)",
      "Bash(operator-sdk:*)",
      "WebFetch(domain:*)"
    ],
    "additionalDirectories": ["/tmp/claude-worktrees"]
  },
  "cleanupPeriodDays": 60,
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["playwright"],
  "enabledPlugins": {
    "semgrep-plugin@semgrep": true
  }
}
