{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go:*)",
      "Bash(bazel:*)",
      "Bash(rg:*)",
      "Bash(curl:*)",
      "WebFetch(domain:*)"
    ]
  },
  "cleanupPeriodDays": 60,
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["playwright"]
}
