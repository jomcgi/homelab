{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "tools/git/check-stale-pr.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cd /tmp/claude-worktrees:*)",
      "Bash(cd /private/tmp/claude-worktrees:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C:*)",
      "Bash(gh:*)",
      "Bash(bazelisk:*)",
      "Bash(format:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(helm dependency:*)",
      "Bash(helm show:*)",
      "Bash(helm uninstall:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(argocd app list:*)",
      "Bash(argocd app get:*)",
      "Bash(argocd app diff:*)",
      "Bash(argocd app history:*)",
      "Bash(go:*)",
      "Bash(operator-sdk:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(lstr:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(crane:*)",
      "Bash(wc:*)",
      "Bash(column:*)",
      "WebFetch(domain:*)",
      "mcp__context-forge__signoz-mcp-signoz-list-services",
      "mcp__context-forge__signoz-mcp-signoz-list-metric-keys",
      "mcp__context-forge__signoz-mcp-signoz-list-log-views",
      "mcp__context-forge__signoz-mcp-signoz-list-dashboards",
      "mcp__context-forge__signoz-mcp-signoz-list-alerts",
      "mcp__context-forge__signoz-mcp-signoz-search-traces-by-service",
      "mcp__context-forge__signoz-mcp-signoz-search-metric-by-text",
      "mcp__context-forge__signoz-mcp-signoz-search-logs-by-service",
      "mcp__context-forge__signoz-mcp-signoz-search-logs",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-span-hierarchy",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-field-values",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-error-analysis",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-details",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-available-fields",
      "mcp__context-forge__signoz-mcp-signoz-get-service-top-operations",
      "mcp__context-forge__signoz-mcp-signoz-get-metrics-field-values",
      "mcp__context-forge__signoz-mcp-signoz-get-metrics-available-fields",
      "mcp__context-forge__signoz-mcp-signoz-get-logs-for-alert",
      "mcp__context-forge__signoz-mcp-signoz-get-logs-field-values",
      "mcp__context-forge__signoz-mcp-signoz-get-logs-available-fields",
      "mcp__context-forge__signoz-mcp-signoz-get-log-view",
      "mcp__context-forge__signoz-mcp-signoz-get-error-logs",
      "mcp__context-forge__signoz-mcp-signoz-get-dashboard",
      "mcp__context-forge__signoz-mcp-signoz-get-alert-history",
      "mcp__context-forge__signoz-mcp-signoz-get-alert",
      "mcp__context-forge__signoz-mcp-signoz-execute-builder-query",
      "mcp__context-forge__signoz-mcp-signoz-aggregate-traces",
      "mcp__context-forge__signoz-mcp-signoz-aggregate-logs"
    ],
    "additionalDirectories": ["/tmp/claude-worktrees"]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true
  }
}
