{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚡ TOKEN CHECK: Reading 10+ files or generating code? Use /opencode (FREE local Qwen). See .claude/skills/opencode/SKILL.md'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go mod:*)",
      "Bash(operator-sdk:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:argo-cd.readthedocs.io)",
      "WebFetch(domain:sdk.operatorframework.io)",
      "WebFetch(domain:book.kubebuilder.io)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:pkg.go.dev)"
    ],
    "additionalDirectories": ["/tmp/claude-worktrees"]
  },
  "cleanupPeriodDays": 60,
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["playwright"]
}
