{
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cd /tmp/claude-worktrees:*)",
      "Bash(cd /private/tmp/claude-worktrees:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C:*)",
      "Bash(gh:*)",
      "Bash(bazelisk:*)",
      "Bash(format:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(helm dependency:*)",
      "Bash(helm show:*)",
      "Bash(helm uninstall:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(go:*)",
      "Bash(operator-sdk:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(lstr:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(crane:*)",
      "Bash(wc:*)",
      "Bash(column:*)",
      "WebFetch(domain:*)",
      "mcp__claude_ai_Homelab__agent-orchestrator-mcp-cancel-job",
      "mcp__claude_ai_Homelab__agent-orchestrator-mcp-get-job",
      "mcp__claude_ai_Homelab__agent-orchestrator-mcp-get-job-output",
      "mcp__claude_ai_Homelab__agent-orchestrator-mcp-list-jobs",
      "mcp__claude_ai_Homelab__agent-orchestrator-mcp-submit-job",
      "mcp__context-forge__agent-orchestrator-mcp-cancel-job",
      "mcp__context-forge__agent-orchestrator-mcp-get-job",
      "mcp__context-forge__agent-orchestrator-mcp-get-job-output",
      "mcp__context-forge__agent-orchestrator-mcp-list-jobs",
      "mcp__context-forge__agent-orchestrator-mcp-submit-job",
      "mcp__context-forge__kubernetes-mcp-resources-list",
      "mcp__context-forge__kubernetes-mcp-resources-get",
      "mcp__context-forge__kubernetes-mcp-pods-top",
      "mcp__context-forge__kubernetes-mcp-pods-run",
      "mcp__context-forge__kubernetes-mcp-pods-log",
      "mcp__context-forge__kubernetes-mcp-pods-list-in-namespace",
      "mcp__context-forge__kubernetes-mcp-pods-list",
      "mcp__context-forge__kubernetes-mcp-pods-get",
      "mcp__context-forge__kubernetes-mcp-nodes-top",
      "mcp__context-forge__kubernetes-mcp-nodes-stats-summary",
      "mcp__context-forge__kubernetes-mcp-nodes-log",
      "mcp__context-forge__kubernetes-mcp-namespaces-list",
      "mcp__context-forge__kubernetes-mcp-helm-list",
      "mcp__context-forge__kubernetes-mcp-helm-install",
      "mcp__context-forge__kubernetes-mcp-events-list",
      "mcp__context-forge__kubernetes-mcp-configuration-view",
      "mcp__context-forge__argocd-mcp-run-resource-action",
      "mcp__context-forge__argocd-mcp-sync-application",
      "mcp__context-forge__argocd-mcp-delete-application",
      "mcp__context-forge__argocd-mcp-update-application",
      "mcp__context-forge__argocd-mcp-create-application",
      "mcp__context-forge__argocd-mcp-get-resource-actions",
      "mcp__context-forge__argocd-mcp-get-resources",
      "mcp__context-forge__argocd-mcp-get-resource-events",
      "mcp__context-forge__argocd-mcp-get-application-events",
      "mcp__context-forge__argocd-mcp-get-application-workload-logs",
      "mcp__context-forge__argocd-mcp-get-application-managed-resources",
      "mcp__context-forge__argocd-mcp-get-application-resource-tree",
      "mcp__context-forge__argocd-mcp-get-application",
      "mcp__context-forge__argocd-mcp-list-applications",
      "Bash(bb:*)",
      "mcp__context-forge__signoz-mcp-signoz-list-services",
      "mcp__context-forge__signoz-mcp-signoz-list-metric-keys",
      "mcp__context-forge__signoz-mcp-signoz-list-log-views",
      "mcp__context-forge__signoz-mcp-signoz-list-dashboards",
      "mcp__context-forge__signoz-mcp-signoz-list-alerts",
      "mcp__context-forge__signoz-mcp-signoz-search-traces-by-service",
      "mcp__context-forge__signoz-mcp-signoz-search-metric-by-text",
      "mcp__context-forge__signoz-mcp-signoz-search-logs-by-service",
      "mcp__context-forge__signoz-mcp-signoz-search-logs",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-span-hierarchy",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-field-values",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-error-analysis",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-details",
      "mcp__context-forge__signoz-mcp-signoz-get-trace-available-fields",
      "mcp__context-forge__signoz-mcp-signoz-get-service-top-operations",
      "mcp__context-forge__signoz-mcp-signoz-get-metrics-field-values",
      "mcp__context-forge__signoz-mcp-signoz-get-metrics-available-fields",
      "mcp__context-forge__signoz-mcp-signoz-get-logs-for-alert",
      "mcp__context-forge__signoz-mcp-signoz-get-logs-field-values",
      "mcp__context-forge__signoz-mcp-signoz-get-logs-available-fields",
      "mcp__context-forge__signoz-mcp-signoz-get-log-view",
      "mcp__context-forge__signoz-mcp-signoz-get-error-logs",
      "mcp__context-forge__signoz-mcp-signoz-get-dashboard",
      "mcp__context-forge__signoz-mcp-signoz-get-alert-history",
      "mcp__context-forge__signoz-mcp-signoz-get-alert",
      "mcp__context-forge__signoz-mcp-signoz-execute-builder-query",
      "mcp__context-forge__signoz-mcp-signoz-aggregate-traces",
      "mcp__context-forge__signoz-mcp-signoz-aggregate-logs"
    ],
    "additionalDirectories": ["/tmp/claude-worktrees"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bazel/tools/git/check-stale-pr.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/prefer-k8s-mcp.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/prefer-argocd-mcp.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/prefer-bb-remote.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bazel/tools/git/check-plan-worktree.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-chart-version-sync.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-copyright-year.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-stale-repo-paths.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-hardcoded-svc-url.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-mcp-run-http.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-ebpf-otel-annotations.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-library-version-bump.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-empty-1password-itempath.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-pdb-single-replica.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-missing-imageupdater.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-missing-argocd-app-build.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-valuesobject-overrides.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-inline-subchart.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-values-chart-version-bump.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-unnecessary-chart-bump.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-hardcoded-llm-model.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bazel/tools/hooks/check-npm-apko-transitive-deps.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "impeccable@impeccable": true
  }
}
